---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import AudioPlayer from '../components/AudioPlayer.astro';
import BottomNav from '../components/BottomNav.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';

interface Props {
	title: string;
	description?: string;
	showNav?: boolean;
	activeNav?: string;
}

const { title, description = "Premium Music Experience", showNav = true, activeNav = 'home' } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap" rel="stylesheet">
		<script is:inline>
			const applyTheme = () => {
				const theme = localStorage.getItem('music-theme') || 'theme-spotify-green';
				const el = document.documentElement;
				// Remove any existing theme- classes
				Array.from(el.classList).forEach(c => {
					if (c.startsWith('theme-')) el.classList.remove(c);
				});
				
				if (theme === 'theme-custom') {
					const customColor = localStorage.getItem('music-theme-custom-color') || '#1ed760';
					el.style.setProperty('--primary', customColor);
					el.style.setProperty('--ring', customColor);
					el.style.setProperty('--sidebar-primary', customColor);
					
					// Contrast text calculation for primary foreground
					const cleanHex = customColor.replace('#', '');
					const r = parseInt(cleanHex.substring(0, 2), 16) || 0;
					const g = parseInt(cleanHex.substring(2, 4), 16) || 0;
					const b = parseInt(cleanHex.substring(4, 6), 16) || 0;
					const yiq = ((r * 299) + (g * 587) + (b * 114)) / 1000;
					const contrast = (yiq >= 128) ? '#000000' : '#ffffff';
					
					el.style.setProperty('--primary-foreground', contrast);
					el.style.setProperty('--sidebar-primary-foreground', contrast);
				} else {
					el.style.removeProperty('--primary');
					el.style.removeProperty('--primary-foreground');
					el.style.removeProperty('--ring');
					el.style.removeProperty('--sidebar-primary');
					el.style.removeProperty('--sidebar-primary-foreground');
					el.classList.add(theme);
				}
				el.classList.add('dark');
			};
			window.applyTheme = applyTheme;
			applyTheme();
			document.addEventListener('astro:after-swap', applyTheme);
			document.addEventListener('astro:page-load', applyTheme);

			// Register service worker for PWA foreground capabilities
			if (typeof window !== 'undefined' && 'serviceWorker' in navigator) {
				window.addEventListener('load', () => {
					navigator.serviceWorker.register('/sw.js')
						.then(reg => console.log('[PWA] Service Worker registered:', reg.scope))
						.catch(err => console.error('[PWA] Service Worker registration failed:', err));
				});
			}
		</script>
	</head>
	<body class="bg-background text-foreground selection:bg-primary/30 antialiased overflow-hidden">
		<!-- Main App Grid Shell -->
		<div class="h-screen w-screen flex flex-col overflow-hidden bg-background">
			<!-- Subtle Background Glow -->
			<div class="fixed inset-0 z-[-1] overflow-hidden pointer-events-none">
				<div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-primary/10 blur-[120px]"></div>
				<div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-blue-500/10 blur-[120px]"></div>
			</div>
			
			<!-- Top Half: Sidebar & main content container -->
			<div class="flex-1 flex min-h-0 overflow-hidden relative">
				{showNav && <Sidebar active={activeNav} />}
				
				<!-- Content Center Panel -->
				<div class="flex-1 flex flex-col min-h-0 overflow-hidden relative">
					{showNav && <Header />}
					
					<!-- Scrollable Content Area -->
					<div id="main-content-scrollable" class="flex-1 overflow-y-auto overflow-x-hidden pb-32">
						<slot />
					</div>
				</div>
			</div>

			<!-- Bottom Panel: Persistent Player -->
			{showNav && <AudioPlayer />}

			<!-- Mobile Bottom Navigation Bar -->
			{showNav && <BottomNav active={activeNav} />}
		</div>
	</body>
</html>

<style is:global>
	:root {
		--font-sans: 'Geist', sans-serif;
	}
	
	/* Custom Scrollbar */
	::-webkit-scrollbar {
		width: 8px;
		height: 8px;
	}
	::-webkit-scrollbar-track {
		background: hsl(var(--background));
	}
	::-webkit-scrollbar-thumb {
		background: hsl(var(--muted-foreground) / 0.2);
		border-radius: 10px;
	}
	::-webkit-scrollbar-thumb:hover {
		background: hsl(var(--muted-foreground) / 0.4);
	}
</style>
