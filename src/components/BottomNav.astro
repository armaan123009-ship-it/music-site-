---
import { Home, Compass, Library, User } from 'lucide-react';

interface Props {
    active?: string;
}

const { active = 'home' } = Astro.props;

const navItems = [
    { id: 'home', label: 'Home', href: '/', icon: Home },
    { id: 'explore', label: 'Explore', href: '/explore', icon: Compass },
    { id: 'library', label: 'Library', href: '/library', icon: Library },
    { id: 'profile', label: 'Account', href: '/profile', icon: User },
];
---

<nav class="fixed bottom-0 left-0 right-0 z-40 xl:hidden bg-background/50 backdrop-blur-2xl border-t border-white/[0.04] px-6 py-2 flex items-center justify-around shadow-2xl safe-bottom transition-all duration-300">
    {navItems.map((item) => {
        const Icon = item.icon;
        const isActive = active === item.id;
        return (
            <a href={item.href} class="flex flex-col items-center justify-center gap-1 py-1.5 px-3 min-w-16 rounded-2xl relative transition-all duration-300 hover:bg-white/5 group">
                <!-- Glowing effect for active item -->
                {isActive && (
                    <div class="absolute -top-2 w-10 h-1 bg-primary rounded-full blur-[2px] shadow-[0_0_8px_var(--primary)] animate-pulse"></div>
                )}
                
                <Icon className={`w-5 h-5 transition-transform duration-300 group-hover:scale-110 group-active:scale-95 ${isActive ? 'text-primary' : 'text-muted-foreground group-hover:text-foreground'}`} />
                
                <span class={`text-[10px] font-bold tracking-tight transition-all duration-300 ${isActive ? 'text-white' : 'text-muted-foreground group-hover:text-foreground'}`}>
                    {item.label}
                </span>
            </a>
        );
    })}
</nav>

<style>
    /* Styling for iOS safe area bottom padding */
    .safe-bottom {
        padding-bottom: calc(0.5rem + env(safe-area-inset-bottom, 0px));
        height: calc(4.5rem + env(safe-area-inset-bottom, 0px));
    }
</style>
