    async function preFetchNextTrack() {
        if (state.currentIndex === -1) return;
        const currentTrack = state.currentQueue[state.currentIndex];
        if (!currentTrack) return;

        // If already successfully pre-fetched for this track, skip
        if (state.preFetchedTrackId === currentTrack.id) return;

        // If currently pre-fetching, skip
        if (state.isPreFetching) return;

        // Rate limit: wait at least 10 seconds between attempts
        const now = Date.now();
        if (
            state.lastPreFetchAttemptTime &&
            now - state.lastPreFetchAttemptTime < 10000
        ) {
            return;
        }
        state.lastPreFetchAttemptTime = now;

        state.isPreFetching = true;
        console.log(
            `[Pre-fetch] Starting pre-fetch sequence for active track: ${currentTrack.title}`,
        );

        try {
            // 1. If Autoplay is enabled and we are playing the last track of the queue, fetch suggestions in advance.
            if (
                state.isAutoplay &&
                state.currentIndex === state.currentQueue.length - 1
            ) {
                console.log(
                    `[Autoplay Pre-fetch] Fetching recommendations in advance for: ${currentTrack.title}`,
                );
                const suggestions = await fetchSuggestions(currentTrack.id);
                if (suggestions && suggestions.length > 0) {
                    const newTracks = suggestions.filter(
                        (s: any) =>
                            !state.currentQueue.some((t: any) => t.id === s.id),
                    );
                    if (newTracks.length > 0) {
                        state.currentQueue.push(...newTracks);
                    } else {
                        const fallbackTrack =
                            suggestions.find(
                                (s: any) => s.id !== currentTrack.id,
                            ) || suggestions[0];
                        if (fallbackTrack) {
                            state.currentQueue.push(fallbackTrack);
                        }
                    }
                    updateQueueUI();
                    saveState();
                }
            }

            // 2. Identify index of the next track
            let nextIndex = -1;
            if (state.currentIndex < state.currentQueue.length - 1) {
                nextIndex = state.currentIndex + 1;
            } else if (
                state.repeatMode === "all" &&
                state.currentQueue.length > 0
            ) {
                nextIndex = 0;
            }

            // 3. Pre-fetch the next track stream details
            if (nextIndex !== -1) {
                const nextTrack = state.currentQueue[nextIndex];
                state.streamUrlCache = state.streamUrlCache || {};
                if (!state.streamUrlCache[nextTrack.id]) {
                    console.log(
                        `[Stream Pre-fetch] Pre-fetching stream details for: ${nextTrack.title}`,
                    );
                    try {
                        const data = await apiFetch(`/stream/${nextTrack.id}`);
                        if (data && data.url) {
                            const proxyUrl = data.proxy_url.startsWith("http")
                                ? data.proxy_url
                                : `${API_BASE}${data.proxy_url}`;
                            state.streamUrlCache[nextTrack.id] = {
                                streamUrl: data.url,
                                proxyUrl: proxyUrl,
                            };
                            console.log(
                                `[Stream Pre-fetch] Successfully pre-fetched stream for: ${nextTrack.title}`,
                            );
                        } else {
                            throw new Error("Invalid stream data");
                        }
                    } catch (e) {
                        console.warn(
                            `Failed to pre-fetch stream URL for ${nextTrack.title}:`,
                            e,
                        );
                        // Try client-side Cobalt pre-fetch fallback across multiple instances
                        const cobaltInstances = [
                            "https://rue-cobalt.xenon.zone",
                            "https://api.cobalt.tools",
                            "https://cobalt.foxtrot-omega.me",
                            "https://cobalt.willy.lol",
                            "https://cobalt.k6.dev",
                            "https://cobalt-api.lunar.icu",
                            "https://cobalt.col1g3.de",
                            "https://cobalt.projectsegfau.lt",
                        ];
                        for (const instance of cobaltInstances) {
                            try {
                                const cobaltRes = await fetch(
                                    instance.endsWith("/")
                                        ? instance
                                        : `${instance}/`,
                                    {
                                        method: "POST",
                                        headers: {
                                            "Content-Type": "application/json",
                                            Accept: "application/json",
                                        },
                                        body: JSON.stringify({
                                            url: `https://www.youtube.com/watch?v=${nextTrack.id}`,
                                        }),
                                    },
                                );
                                if (cobaltRes.ok) {
                                    const cobaltData = await cobaltRes.json();
                                    const sUrl =
                                        cobaltData.url || cobaltData.picker;
                                    if (sUrl) {
                                        state.streamUrlCache[nextTrack.id] = {
                                            streamUrl: sUrl,
                                            proxyUrl: sUrl,
                                        };
                                        console.log(
                                            `[Stream Pre-fetch] Successfully pre-fetched client-side stream via ${instance} for: ${nextTrack.title}`,
                                        );
                                        break;
                                    }
                                }
                            } catch (prefErr) {
                                // continue to next instance
                            }
                        }
                    }
                }
            }

            // Mark pre-fetch sequence as successful for this track
            state.preFetchedTrackId = currentTrack.id;
        } catch (e) {
            console.warn(
                `[Pre-fetch] Pre-fetch attempt failed for ${currentTrack.title}:`,
                e,
            );
            // Do not set preFetchedTrackId, allowing retry on next trigger window
        } finally {
            state.isPreFetching = false;
        }
    }

    async function fetchStreamAndPlay(track: any) {
        if (!track) return;
        try {
            // Update UI details immediately for instant feedback
            titleEls().forEach((el) => el && (el.textContent = track.title));
            artistEls().forEach((el) => el && (el.textContent = track.artist));
            artworkEls().forEach((el) => {
                if (el) {
                    el.classList.add("opacity-0");
                    el.dataset.id = track.id;
                    (el as HTMLImageElement).src = track.image;
                }
            });
            updateLikeUI(track.id);

            // Force browser to load the artwork image immediately
            if (track.image) {
                const imgLoader = new Image();
                imgLoader.src = track.image;
            }

            // Update artwork glow gradient dynamically
            const glowEl = document.getElementById("immersive-artwork-glow");
            if (glowEl) {
                glowEl.style.background = getGlowGradient(track.title);
            }

            // Unregister previous error handlers and pause immediately to prevent false playback abort error toasts
            audio.onerror = null;
            audio.pause();
            audio.src = "";
            try {
                audio.load();
            } catch (e) {}

            let streamUrl = null;
            let proxyUrl = null;

            // Check client-side cache first
            state.streamUrlCache = state.streamUrlCache || {};
            if (state.streamUrlCache[track.id]) {
                const cached = state.streamUrlCache[track.id];
                streamUrl = cached.streamUrl;
                proxyUrl = cached.proxyUrl;
                state.currentStreamUrl = streamUrl;
                state.currentProxyUrl = proxyUrl;
                console.log(
                    `[Cache Hit] Playing from pre-fetched stream cache for: ${track.title}`,
                );
            } else {
                try {
                    const data = await apiFetch(`/stream/${track.id}`);
                    if (data && data.url) {
                        streamUrl = data.url;
                        // proxy_url is expected to be a relative path like /proxy?... on the Flask backend.
                        // Only prefix API_BASE when needed.
                        if (data.proxy_url) {
                            proxyUrl = data.proxy_url.startsWith("http")
                                ? data.proxy_url
                                : `${API_BASE}${data.proxy_url}`;
                        }
                        state.currentStreamUrl = streamUrl;
                        state.currentProxyUrl = proxyUrl;
                    }
                    console.log("[Stream Debug]", {
                        trackId: track.id,
                        resolved: data,
                        computedStreamUrl: streamUrl,
                        computedProxyUrl: proxyUrl,
                        API_BASE,
                    });
                } catch (err) {
                    console.warn("Failed to retrieve stream details:", err);
                }
            }

            // Fallback: If server failed to resolve streaming URLs, resolve client-side
            if (!proxyUrl) {
                const resolved = await resolveStreamClientSide(track.id);
                if (resolved) {
                    streamUrl = resolved.streamUrl;
                    proxyUrl = resolved.proxyUrl;
                    state.currentStreamUrl = streamUrl;
                    state.currentProxyUrl = proxyUrl;
                }
            }

            // Always use proxy when it exists to route requests through our Vercel proxy.
            const useProxy = !!proxyUrl;

            let playbackAttempts = 0; // 0 = proxy, 1 = direct, 2 = client fallback
            let triedUrls = new Set<string>();

            const attemptPlayback = async () => {
                try {
                    let currentPlayUrl = "";
                    if (playbackAttempts === 0) {
                        currentPlayUrl = proxyUrl || "";
                        console.log(`[Playback] Attempt 1: Playing through proxy: ${currentPlayUrl}`);
                    } else if (playbackAttempts === 1) {
                        currentPlayUrl = streamUrl || "";
                        console.log(`[Playback] Attempt 2: Playing direct stream: ${currentPlayUrl}`);
                    } else if (playbackAttempts === 2) {
                        console.log(`[Playback] Attempt 3: Resolving and playing client-side fallback...`);
                        showToast("Resolving backup stream...");
                        const resolved = await resolveStreamClientSide(track.id);
                        if (resolved) {
                            streamUrl = resolved.streamUrl;
                            proxyUrl = resolved.proxyUrl;
                            state.streamUrlCache[track.id] = resolved;
                            currentPlayUrl = resolved.proxyUrl;
                        }
                    }

                    if (currentPlayUrl && currentPlayUrl !== window.location.href && !triedUrls.has(currentPlayUrl)) {
                        triedUrls.add(currentPlayUrl);
                        audio.src = currentPlayUrl;
                        await audio.play();
                        syncPlayPauseUI(true);
                        requestWakeLock();
                        state.isPreFetching = false;
                        preFetchNextTrack();
                    } else {
                        // Skip to next attempt if url is invalid/empty or already tried
                        throw new Error("Invalid or duplicate URL");
                    }
                } catch (err: any) {
                    if (err && err.name === "NotAllowedError") {
                        console.log("Autoplay blocked by browser. Awaiting user interaction.");
                        syncPlayPauseUI(false);
                        return;
                    }
                    console.warn(`[Playback] Attempt ${playbackAttempts + 1} failed:`, err);
                    playbackAttempts++;
                    if (playbackAttempts <= 2) {
                        await attemptPlayback();
                    } else {
                        syncPlayPauseUI(false);
                        releaseWakeLock();
                        showToast("Playback failed.");
                    }
                }
            };

            audio.onerror = async () => {
                console.warn("[Playback] Browser triggered audio.onerror");
                playbackAttempts++;
                if (playbackAttempts <= 2) {
                    await attemptPlayback();
                } else {
                    syncPlayPauseUI(false);
                    releaseWakeLock();
                    showToast("Playback failed.");
                }
            };

            updateMediaSession(track);
            miniPlayer?.classList.remove("translate-y-full");
            await attemptPlayback();

            if (state.activeTab === "lyrics") {
                updateLyrics(track.id);
            } else {
                const lyr = lyricsContent();
                if (lyr)
                    lyr.innerHTML =
                        '<p class="opacity-50 italic">Select a track to see lyrics...</p>';
            }
            updateRelatedUI(track.id);
            updateQueueUI();
            saveState();
        } catch (err) {
            console.error("Playback failed:", err);
            titleEls().forEach(
                (el) => el && (el.textContent = "Playback Error"),
            );
        }
    }

    function updateLikeUI(songId: string) {
        const likeIcon = miniLikeIcon();
        const likeBtn = miniLikeBtn();
        const immLikeIcon = document.getElementById("immersive-like-icon");
        const immLikeBtn = document.getElementById("immersive-like-btn");
        if (!state.currentUser || !state.currentUser.logged_in) {
            likeBtn?.classList.add("hidden");
            immLikeBtn?.classList.add("hidden");
            return;
        }
        likeBtn?.classList.remove("hidden");
        immLikeBtn?.classList.remove("hidden");
        const isLiked = state.currentUser.liked_songs.some(
            (s: any) => s.id === songId,
        );
        if (isLiked) {
            likeIcon?.classList.add("fill-primary", "text-primary");
            likeIcon?.setAttribute("fill", "currentColor");
            immLikeIcon?.classList.add("fill-primary", "text-primary");
            immLikeIcon?.setAttribute("fill", "currentColor");
        } else {
            likeIcon?.classList.remove("fill-primary", "text-primary");
            likeIcon?.setAttribute("fill", "none");
            immLikeIcon?.classList.remove("fill-primary", "text-primary");
            immLikeIcon?.setAttribute("fill", "none");
        }
    }

    async function handleLikeToggle(e: Event) {
        e.stopPropagation();
        if (
            !state.currentUser ||
            !state.currentUser.logged_in ||
            state.currentIndex === -1
        )
            return;
        const currentTrack = state.currentQueue[state.currentIndex];
        const isLiked = state.currentUser.liked_songs.some(
            (s: any) => s.id === currentTrack.id,
        );
        const action = isLiked ? "remove" : "add";

        if (action === "add") {
            state.currentUser.liked_songs.push(currentTrack);
        } else {
            state.currentUser.liked_songs =
                state.currentUser.liked_songs.filter(
                    (s: any) => s.id !== currentTrack.id,
                );
        }
        updateLikeUI(currentTrack.id);

        const res = await toggleLike(currentTrack, action);
        if (res && res.success) {
            state.currentUser.liked_songs = res.liked_songs;
        }
    }

    async function updateLyrics(id: string) {
        const lyr = lyricsContent();
        if (lyr)
            lyr.innerHTML =
                '<p class="animate-pulse text-sm text-white/50 text-center py-8">Fetching lyrics...</p>';

        let track = state.currentQueue[state.currentIndex];
        let queryParams = "";
        if (track) {
            queryParams = `?title=${encodeURIComponent(track.title)}&artist=${encodeURIComponent(track.artist)}`;
        }

        const data = await apiFetch(`/api/lyrics/${id}${queryParams}`);
        const lyrUpdate = lyricsContent();
        if (lyrUpdate && data) {
            const isSynced = data.synced;
            const lyrics = data.lyrics;

            if (isSynced && lyrics && lyrics !== "No lyrics found.") {
                state.parsedLyrics = parseLRC(lyrics);
                state.lastActiveLyricIdx = -1;

                lyrUpdate.innerHTML = `
                    <div id="lyrics-lines-container" class="space-y-6 text-center py-10 px-4 transition-all duration-300">
                        ${state.parsedLyrics
                            .map(
                                (line: any, idx: number) => `
                            <p class="lyric-line text-lg sm:text-2xl font-black text-white/40 transition-all duration-500 cursor-pointer select-none leading-relaxed px-2 py-1 hover:text-white" 
                               data-time="${line.time}" data-index="${idx}">
                                ${line.text}
                            </p>
                        `,
                            )
                            .join("")}
                    </div>
                `;

                lyrUpdate.querySelectorAll(".lyric-line").forEach((el) => {
                    el.addEventListener("click", () => {
                        const seekTime = parseFloat(
                            (el as HTMLElement).dataset.time!,
                        );
                        if (!isNaN(seekTime)) {
                            audio.currentTime = seekTime;
                            updateActiveLyric(seekTime); // Highlight and scroll immediately on click!
                        }
                    });
                });

                // Highlight active line immediately when loaded!
                updateActiveLyric(audio.currentTime);
            } else {
                state.parsedLyrics = [];
                state.lastActiveLyricIdx = -1;
                lyrUpdate.innerHTML =
                    lyrics && lyrics !== "No lyrics found."
                        ? `<div class="text-center text-white/95 text-base md:text-lg leading-loose px-2 py-4">${lyrics.replace(/\n/g, "<br/>")}</div>`
                        : '<p class="text-sm text-white/40 text-center py-8">No lyrics found for this track.</p>';
            }
        } else if (lyrUpdate) {
            lyrUpdate.innerHTML =
                '<p class="text-sm text-white/40 text-center py-8">No lyrics found for this track.</p>';
        }
    }

    function updateActiveLyric(currentTime: number) {
        const linesContainer = document.getElementById(
            "lyrics-lines-container",
        );
        if (
            !linesContainer ||
            !state.parsedLyrics ||
            state.parsedLyrics.length === 0
        )
            return;

        let activeIdx = -1;
        for (let i = 0; i < state.parsedLyrics.length; i++) {
            if (currentTime >= state.parsedLyrics[i].time) {
                activeIdx = i;
            } else {
                break;
            }
        }

        const lineElements = linesContainer.querySelectorAll(".lyric-line");
        lineElements.forEach((el, idx) => {
            if (idx === activeIdx) {
                el.classList.remove("text-white/40");
                el.classList.add("text-primary", "scale-105", "font-black");
                el.style.opacity = "1";
                el.style.textShadow = "0 0 15px var(--primary)";

                if (state.lastActiveLyricIdx !== activeIdx) {
                    state.lastActiveLyricIdx = activeIdx;
                    el.scrollIntoView({ behavior: "smooth", block: "center" });
                }
            } else {
                el.classList.add("text-white/40");
                el.classList.remove("text-primary", "scale-105", "font-black");
                el.style.opacity = "0.4";
                el.style.textShadow = "none";
            }
        });
    }

    async function updateRelatedUI(id: string) {
        const relContainer = document.getElementById("related-list-container");
        if (!relContainer) return;
        relContainer.innerHTML =
            '<p class="animate-pulse text-xs text-white/50 text-center py-8">Fetching suggestions...</p>';
        try {
            const tracks = await fetchSuggestions(id);
            if (tracks && tracks.length > 0) {
                relContainer.innerHTML = tracks
                    .map(
                        (track: any) => `
                    <div class="track-trigger flex items-center justify-between p-3 rounded-2xl hover:bg-white/5 group transition-all cursor-pointer related-item"
