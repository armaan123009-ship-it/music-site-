                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                        </button>
                    </div>
                `,
                    )
                    .join("");
            } else {
                relContainer.innerHTML =
                    '<p class="text-xs text-white/40 text-center py-8">No suggestions found.</p>';
            }
        } catch (e) {
            relContainer.innerHTML =
                '<p class="text-xs text-red-400 text-center py-8">Error loading suggestions.</p>';
        }
    }

    function removeFromQueue(index: number) {
        if (index < 0 || index >= state.currentQueue.length) return;

        state.currentQueue.splice(index, 1);
        if (state.currentIndex === index) {
            if (state.currentQueue.length === 0) {
                state.currentIndex = -1;
                audio.pause();
                syncPlayPauseUI(false);
                releaseWakeLock();
            } else {
                state.currentIndex = Math.min(
                    index,
                    state.currentQueue.length - 1,
                );
                fetchStreamAndPlay(state.currentQueue[state.currentIndex]);
            }
        } else if (state.currentIndex > index) {
            state.currentIndex--;
        }

        updateQueueUI();
        saveState();
    }

    function moveQueueItem(index: number, direction: "up" | "down") {
        const newIndex = direction === "up" ? index - 1 : index + 1;
        if (newIndex < 0 || newIndex >= state.currentQueue.length) return;

        const temp = state.currentQueue[index];
        state.currentQueue[index] = state.currentQueue[newIndex];
        state.currentQueue[newIndex] = temp;

        if (state.currentIndex === index) {
            state.currentIndex = newIndex;
        } else if (state.currentIndex === newIndex) {
            state.currentIndex = index;
        }

        updateQueueUI();
        saveState();
    }

    function updateQueueUI() {
        const qContainer = queueListContainer();
        if (!qContainer) return;
        qContainer.innerHTML = state.currentQueue
            .map(
                (track: any, idx: number) => `
            <div class="flex items-center justify-between p-3 rounded-2xl ${idx === state.currentIndex ? "bg-primary text-primary-foreground font-bold shadow-lg shadow-primary/10" : "hover:bg-white/5"} transition-all cursor-pointer queue-item group/item" data-index="${idx}">
                <div class="flex items-center gap-3 pointer-events-none min-w-0 flex-1">
                    <img src="${track.image}" referrerpolicy="no-referrer" class="w-10 h-10 rounded-xl object-cover shrink-0 transition-opacity duration-300 opacity-0" onload="this.classList.remove('opacity-0')" onerror="this.onerror=null; this.src='https://i.ytimg.com/vi/${track.id}/hqdefault.jpg';" />
                    <div class="min-w-0">
                        <p class="font-bold text-sm ${idx === state.currentIndex ? "text-primary-foreground" : "text-white"} truncate">${track.title}</p>
                        <p class="text-xs opacity-70 ${idx === state.currentIndex ? "text-primary-foreground/85" : "text-white/70"} truncate">${track.artist}</p>
                    </div>
                </div>
                
                <div class="flex items-center gap-1 shrink-0 ml-2">
                    ${
                        idx > 0
                            ? `
                        <button class="queue-move-up-btn p-1.5 hover:bg-white/10 rounded-lg ${idx === state.currentIndex ? "text-primary-foreground/70 hover:text-primary-foreground" : "text-white/60 hover:text-white"} transition-all cursor-pointer" data-index="${idx}" title="Move track up">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><path d="m18 15-6-6-6 6"/></svg>
                        </button>
                    `
                            : ""
                    }
                    
                    ${
                        idx < state.currentQueue.length - 1
                            ? `
                        <button class="queue-move-down-btn p-1.5 hover:bg-white/10 rounded-lg ${idx === state.currentIndex ? "text-primary-foreground/70 hover:text-primary-foreground" : "text-white/60 hover:text-white"} transition-all cursor-pointer" data-index="${idx}" title="Move track down">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><path d="m6 9 6 6 6-6"/></svg>
                        </button>
                    `
                            : ""
                    }
                    
                    <button class="queue-remove-btn p-1.5 hover:bg-white/10 rounded-lg ${idx === state.currentIndex ? "text-primary-foreground/70 hover:text-red-300" : "text-white/60 hover:text-red-400"} transition-all cursor-pointer" data-index="${idx}" title="Remove track from queue">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                    </button>
                </div>
            </div>
        `,
            )
            .join("");

        qContainer.querySelectorAll(".queue-remove-btn").forEach((btn) => {
            btn.addEventListener("click", (e) => {
                e.stopPropagation();
                const index = parseInt((btn as HTMLElement).dataset.index!);
                removeFromQueue(index);
            });
        });

        qContainer.querySelectorAll(".queue-move-up-btn").forEach((btn) => {
            btn.addEventListener("click", (e) => {
                e.stopPropagation();
                const index = parseInt((btn as HTMLElement).dataset.index!);
                moveQueueItem(index, "up");
            });
        });

        qContainer.querySelectorAll(".queue-move-down-btn").forEach((btn) => {
            btn.addEventListener("click", (e) => {
                e.stopPropagation();
                const index = parseInt((btn as HTMLElement).dataset.index!);
                moveQueueItem(index, "down");
            });
        });

        qContainer.querySelectorAll(".queue-item").forEach((item) => {
            item.addEventListener("click", (e) => {
                const target = e.target as HTMLElement;
                if (target.closest("button")) return;

                syncUnlockAudio();
                const index = parseInt((item as HTMLElement).dataset.index!);
                state.currentIndex = index;
                fetchStreamAndPlay(state.currentQueue[state.currentIndex]);
            });
        });
    }

    async function fetchAutoplayAndPlay() {
        const lastTrack = state.currentQueue[state.currentIndex];
        titleEls().forEach(
            (el) => el && (el.textContent = "Autoplay recommendations..."),
        );
        try {
            const suggestions = await fetchSuggestions(lastTrack.id);
            if (suggestions && suggestions.length > 0) {
                const newTracks = suggestions.filter(
                    (s: any) =>
                        !state.currentQueue.some((t: any) => t.id === s.id),
                );
                let nextTrackToPlay = null;
                if (newTracks.length > 0) {
                    state.currentQueue.push(...newTracks);
                    nextTrackToPlay = newTracks[0];
                } else {
                    const fallbackTrack =
                        suggestions.find((s: any) => s.id !== lastTrack.id) ||
                        suggestions[0];
                    if (fallbackTrack) {
                        state.currentQueue.push(fallbackTrack);
                        nextTrackToPlay = fallbackTrack;
                    }
                }

                if (nextTrackToPlay) {
                    state.currentIndex = state.currentQueue.length - 1;
                    updateQueueUI();
                    fetchStreamAndPlay(state.currentQueue[state.currentIndex]);
                }
            }
        } catch (e) {
            console.error("Autoplay suggestions fetch failed:", e);
        }
    }

    function playNextTrack() {
        if (state.currentQueue.length === 0) return;

        let nextIndex = state.currentIndex + 1;
        if (nextIndex >= state.currentQueue.length) {
            if (state.repeatMode === "all") {
                nextIndex = 0;
            } else {
                if (state.isAutoplay) {
                    fetchAutoplayAndPlay();
                } else {
                    audio.pause();
                    syncPlayPauseUI(false);
                    releaseWakeLock();
                }
                return;
            }
        }

        state.currentIndex = nextIndex;
        const track = state.currentQueue[state.currentIndex];

        // Synchronous cache play check
        const cached = state.streamUrlCache && state.streamUrlCache[track.id];
        if (cached && (cached.proxyUrl || cached.streamUrl)) {
            console.log(
                `[Sync Autoplay] Cache hit for ${track.title}. Transitioning synchronously.`,
            );

            // Always use proxy when it exists to route requests through our Vercel proxy.
            const useProxy = !!cached.proxyUrl;
            const playUrl = useProxy ? cached.proxyUrl : cached.streamUrl;

            // Set source directly
            audio.src = playUrl;

            // Sync UI details synchronously
            titleEls().forEach((el) => el && (el.textContent = track.title));
            artistEls().forEach((el) => el && (el.textContent = track.artist));
            artworkEls().forEach(
                (el) => el && ((el as HTMLImageElement).src = track.image),
            );

            const glowEl = document.getElementById("immersive-artwork-glow");
            if (glowEl) glowEl.style.background = getGlowGradient(track.title);

            updateMediaSession(track);
            updateQueueUI();
            updateRelatedUI(track.id);
            if (state.activeTab === "lyrics") {
                updateLyrics(track.id);
            }

            requestWakeLock();
            audio
                .play()
                .then(() => {
                    syncPlayPauseUI(true);
                    state.isPreFetching = false;
                    preFetchNextTrack();
                })
                .catch((err) => {
                    console.warn(
                        "[Sync Autoplay] Play rejected, falling back to fetchStreamAndPlay",
                        err,
                    );
                    fetchStreamAndPlay(track);
                });
        } else {
            console.log(
                `[Sync Autoplay] Cache miss for ${track.title}. Falling back to async fetch.`,
            );
            fetchStreamAndPlay(track);
        }
    }

    function nextTrack() {
        playNextTrack();
    }

    function prevTrack() {
        if (state.currentQueue.length === 0) return;
        state.currentIndex =
            (state.currentIndex - 1 + state.currentQueue.length) %
            state.currentQueue.length;
        fetchStreamAndPlay(state.currentQueue[state.currentIndex]);
    }

    function saveState() {
        localStorage.setItem(
            "premium_music_state",
            JSON.stringify({
                queue: state.currentQueue,
                originalQueue: state.originalQueue,
                index: state.currentIndex,
                shuffle: state.isShuffle,
                repeat: state.repeatMode,
            }),
        );
    }

    function updateControlsUI() {
        const sBtn = shuffleBtn();
        const immSBtn = document.getElementById("immersive-shuffle-btn");
        if (state.isShuffle) {
            sBtn?.classList.add("text-primary");
            sBtn?.classList.remove("text-muted-foreground");
            immSBtn?.classList.add("text-primary");
            immSBtn?.classList.remove("text-muted-foreground");
        } else {
            sBtn?.classList.remove("text-primary");
            sBtn?.classList.add("text-muted-foreground");
            immSBtn?.classList.remove("text-primary");
            immSBtn?.classList.add("text-muted-foreground");
        }

        const rBtn = repeatBtn();
        const immRBtn = document.getElementById("immersive-repeat-btn");

        const applyRepeatStyle = (btn: HTMLElement | null) => {
            if (!btn) return;
            if (state.repeatMode === "none") {
                btn.classList.add("text-muted-foreground");
                btn.classList.remove("text-primary");
                btn.querySelector(".repeat-badge")?.remove();
            } else if (state.repeatMode === "all") {
                btn.classList.add("text-primary");
                btn.classList.remove("text-muted-foreground");
                btn.querySelector(".repeat-badge")?.remove();
            } else if (state.repeatMode === "one") {
                btn.classList.add("text-primary");
                btn.classList.remove("text-muted-foreground");
                if (!btn.querySelector(".repeat-badge")) {
                    const badge = document.createElement("span");
                    badge.className =
                        "repeat-badge absolute -top-1 -right-1 text-[8px] font-black bg-primary text-primary-foreground rounded-full w-3.5 h-3.5 flex items-center justify-center";
                    badge.innerText = "1";
                    btn.appendChild(badge);
                }
            }
        };

        applyRepeatStyle(rBtn);
        applyRepeatStyle(immRBtn);

        const aBtn = autoplayBtn();
        const aTgl = autoplayToggle();
        if (state.isAutoplay) {
            aBtn?.classList.add("text-primary");
            aBtn?.classList.remove("text-muted-foreground");
            if (aTgl) aTgl.checked = true;
        } else {
            aBtn?.classList.remove("text-primary");
            aBtn?.classList.add("text-muted-foreground");
            if (aTgl) aTgl.checked = false;
        }
    }

    function handleShuffleToggle() {
        if (state.currentQueue.length === 0) return;
        state.isShuffle = !state.isShuffle;
        if (state.isShuffle) {
            state.originalQueue = [...state.currentQueue];
            const currentTrack = state.currentQueue[state.currentIndex];
            const remaining = state.currentQueue.filter(
                (_: any, idx: number) => idx !== state.currentIndex,
            );

            for (let i = remaining.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [remaining[i], remaining[j]] = [remaining[j], remaining[i]];
            }

            state.currentQueue = [currentTrack, ...remaining];
            state.currentIndex = 0;
        } else {
            const currentTrack = state.currentQueue[state.currentIndex];
            if (state.originalQueue.length > 0) {
                state.currentQueue = [...state.originalQueue];
                state.currentIndex = state.currentQueue.findIndex(
                    (t: any) => t.id === currentTrack.id,
                );
            }
        }
        updateQueueUI();
        updateControlsUI();
        saveState();
    }

    function handleRepeatToggle() {
        if (state.repeatMode === "none") {
            state.repeatMode = "all";
        } else if (state.repeatMode === "all") {
            state.repeatMode = "one";
        } else {
            state.repeatMode = "none";
        }
        updateControlsUI();
        saveState();
    }

    function handleAutoplayToggle(e?: Event) {
        const aTgl = autoplayToggle();
        if (e && e.target === aTgl) {
            state.isAutoplay = aTgl.checked;
        } else {
            state.isAutoplay = !state.isAutoplay;
        }
        localStorage.setItem(
            "premium_music_autoplay",
            state.isAutoplay.toString(),
        );
        updateControlsUI();
    }

    const toggleImmersive = () =>
        immersivePlayer?.classList.toggle("translate-y-full");

    function loadState() {
        const savedAutoplay = localStorage.getItem("premium_music_autoplay");
        if (savedAutoplay !== null) {
            state.isAutoplay = savedAutoplay === "true";
        }

        if (state.currentQueue.length > 0 && state.currentIndex !== -1) {
            const track = state.currentQueue[state.currentIndex];
            titleEls().forEach((el) => el && (el.textContent = track.title));
            artistEls().forEach((el) => el && (el.textContent = track.artist));
            artworkEls().forEach(
                (el) => el && ((el as HTMLImageElement).src = track.image),
            );

            const glowEl = document.getElementById("immersive-artwork-glow");
            if (glowEl) glowEl.style.background = getGlowGradient(track.title);

            miniPlayer?.classList.remove("translate-y-full");
            updateQueueUI();
            if (state.activeTab === "lyrics") {
                updateLyrics(track.id);
            } else {
                const lyr = lyricsContent();
                if (lyr)
                    lyr.innerHTML =
                        '<p class="opacity-50 italic">Select a track to see lyrics...</p>';
            }
            updateRelatedUI(track.id);

            syncPlayPauseUI(state.isPlaying);
            updateControlsUI();
            return;
        }

        const saved = localStorage.getItem("premium_music_state");
        if (saved) {
            try {
                const loadedState = JSON.parse(saved);
                state.currentQueue = loadedState.queue || [];
                state.originalQueue = loadedState.originalQueue || [];
                state.currentIndex = loadedState.index || -1;
                state.isShuffle = loadedState.shuffle || false;
                state.repeatMode = loadedState.repeat || "none";
                if (
                    state.currentIndex !== -1 &&
                    state.currentQueue[state.currentIndex]
                ) {
                    const track = state.currentQueue[state.currentIndex];
                    titleEls().forEach(
                        (el) => el && (el.textContent = track.title),
                    );
                    artistEls().forEach(
                        (el) => el && (el.textContent = track.artist),
                    );
                    artworkEls().forEach(
                        (el) =>
                            el && ((el as HTMLImageElement).src = track.image),
                    );

                    const glowEl = document.getElementById(
                        "immersive-artwork-glow",
                    );
                    if (glowEl)
                        glowEl.style.background = getGlowGradient(track.title);

                    miniPlayer?.classList.remove("translate-y-full");
                    updateQueueUI();
                    if (state.activeTab === "lyrics") {
                        updateLyrics(track.id);
                    } else {
                        const lyr = lyricsContent();
                        if (lyr)
                            lyr.innerHTML =
                                '<p class="opacity-50 italic">Select a track to see lyrics...</p>';
                    }
                    updateRelatedUI(track.id);
                }
            } catch (e) {}
        }
        updateControlsUI();
        initUser();
    }

    function initPlayer() {
        audio = document.getElementById("main-audio") as HTMLAudioElement;
        miniPlayer = document.getElementById("audio-player");
        immersivePlayer = document.getElementById("immersive-player");

        if (!audio) return;

        // Register Media Session action handlers
        if ("mediaSession" in navigator) {
            navigator.mediaSession.setActionHandler("play", () => {
                audio.play().catch(() => {});
            });
            navigator.mediaSession.setActionHandler("pause", () => {
                audio.pause();
            });
            navigator.mediaSession.setActionHandler("previoustrack", prevTrack);
            navigator.mediaSession.setActionHandler("nexttrack", nextTrack);
            try {
                navigator.mediaSession.setActionHandler("seekto", (details) => {
                    if (details.seekTime !== undefined) {
                        audio.currentTime = details.seekTime;
                    }
                });
            } catch (e) {}
        }

        // HTML5 Audio element listeners
        audio.onended = () => {
            if (state.repeatMode === "one") {
                audio.currentTime = 0;
                audio.play();
            } else {
                playNextTrack();
            }
        };
        audio.onplay = () => {
            syncPlayPauseUI(true);
            requestWakeLock();
        };
        audio.onpause = () => {
            syncPlayPauseUI(false);
            releaseWakeLock();
        };
        audio.ontimeupdate = () => {
            const duration = getDuration() || 1;
            const progress = (audio.currentTime / duration) * 100;
            updateProgressUI(audio.currentTime, duration, progress);
            updatePlaybackPosition();
            updateActiveLyric(audio.currentTime);

            // Pre-fetch starting at 25% progress
            if (progress >= 25) {
                preFetchNextTrack();
            }
        };
        audio.onloadedmetadata = () => {
            const duration = getDuration() || 1;
            const progress = (audio.currentTime / duration) * 100;
            updateProgressUI(audio.currentTime, duration, progress);
        };

        // Attach event listeners to player controls
        const togglePlay = () => {
            const nextPlayingState = !state.isPlaying;
            syncPlayPauseUI(nextPlayingState);

            const currentSrc = audio.src;
            if (
                !currentSrc ||
                currentSrc === window.location.href ||
                currentSrc.endsWith("/")
            ) {
                if (
                    state.currentIndex !== -1 &&
                    state.currentQueue[state.currentIndex]
                ) {
                    syncUnlockAudio();
                    fetchStreamAndPlay(state.currentQueue[state.currentIndex]);
                    return;
                }
            }

            if (nextPlayingState) {
                audio
                    .play()
                    .then(() => {
                        requestWakeLock();
                    })
                    .catch((err) => {
                        console.warn(
                            "Audio play failed, reverting UI state:",
                            err,
                        );
                        syncPlayPauseUI(false);
                        releaseWakeLock();
                    });
            } else {
                audio.pause();
                releaseWakeLock();
            }
        };

        // Bind play/pause
        const playPauseBtn = document.getElementById("play-pause-btn");
        if (playPauseBtn && !playPauseBtn.dataset.bound) {
            playPauseBtn.dataset.bound = "true";
            playPauseBtn.addEventListener("click", togglePlay);
        }

        const mobMiniPlayPause = document.getElementById(
            "mobile-mini-play-pause",
        );
        if (mobMiniPlayPause && !mobMiniPlayPause.dataset.bound) {
            mobMiniPlayPause.dataset.bound = "true";
            mobMiniPlayPause.addEventListener("click", (e) => {
                e.stopPropagation();
                togglePlay();
            });
        }

        const immPlayPauseBtn = document.getElementById(
            "immersive-play-pause-btn",
        );
        if (immPlayPauseBtn && !immPlayPauseBtn.dataset.bound) {
            immPlayPauseBtn.dataset.bound = "true";
            immPlayPauseBtn.addEventListener("click", togglePlay);
        }

        // Next and Prev binding
        const bindControl = (
            id: string,
            action: () => void,
            stopEvent: boolean = false,
        ) => {
            const btn = document.getElementById(id);
            if (btn && !btn.dataset.bound) {
                btn.dataset.bound = "true";
                btn.addEventListener("click", (e) => {
                    if (stopEvent) e.stopPropagation();
                    action();
                });
            }
        };

        bindControl("next-btn", nextTrack);
        bindControl("immersive-next-btn", nextTrack);
        bindControl("mobile-mini-next", nextTrack, true);
        bindControl("prev-btn", prevTrack);
        bindControl("immersive-prev-btn", prevTrack);

        // Shuffles & Repeats
        bindControl("shuffle-btn", handleShuffleToggle);
        bindControl("immersive-shuffle-btn", handleShuffleToggle);
        bindControl("repeat-btn", handleRepeatToggle);
        bindControl("immersive-repeat-btn", handleRepeatToggle);
        bindControl("autoplay-btn", handleAutoplayToggle);

        const aTgl = autoplayToggle();
        if (aTgl && !aTgl.dataset.bound) {
            aTgl.dataset.bound = "true";
            aTgl.addEventListener("change", handleAutoplayToggle);
        }

        // Likes
        bindControl("mini-like-btn", handleLikeToggle as any);
        bindControl("immersive-like-btn", handleLikeToggle as any);

        // Download bindings
        const handleDownload = async () => {
            if (
                state.currentIndex === -1 ||
                !state.currentQueue[state.currentIndex]
            )
                return;
            const track = state.currentQueue[state.currentIndex];

            const downloadBtns = [
                document.getElementById("mini-download-btn"),
                document.getElementById("mobile-mini-download"),
                document.getElementById("immersive-download-btn"),
            ];

            const updateDownloadProgress = (text: string, active: boolean) => {
                downloadBtns.forEach((btn) => {
                    if (btn) {
                        if (active) {
                            btn.classList.add("animate-pulse", "text-primary");
                            btn.setAttribute("title", text);
                        } else {
                            btn.classList.remove(
                                "animate-pulse",
                                "text-primary",
                            );
                            btn.setAttribute("title", "Download song");
                        }
                    }
                });
            };

            updateDownloadProgress("Preparing...", true);

            const isLocalhost =
                window.location.hostname === "localhost" ||
                window.location.hostname === "127.0.0.1";

            try {
                let streamUrl = state.currentStreamUrl;
                let proxyUrl = state.currentProxyUrl;

                // Force resolving a fresh signed stream link for the download operation
                const data = await apiFetch(`/stream/${track.id}`);
                if (data) {
                    streamUrl = data.url;
                    proxyUrl = data.proxy_url.startsWith("http")
                        ? data.proxy_url
                        : `${API_BASE}${data.proxy_url}`;
                }

                if (!streamUrl) {
                    throw new Error("Unable to resolve streaming URL");
                }

                // If on production Vercel, redirect directly to the backend download endpoint.
                // The backend redirects to a playable direct attachment URL to bypass Vercel constraints.
                if (!isLocalhost) {
                    console.log(
                        "[Downloader] Using production download redirect endpoint...",
                    );
                    updateDownloadProgress("Downloading...", true);
                    window.location.href = `${API_BASE}/api/download/${track.id}?title=${encodeURIComponent(track.title)}`;
                    setTimeout(
                        () =>
                            updateDownloadProgress("Download complete", false),
                        2000,
                    );
                    return;
                }

                // Range request for 0-0 to retrieve total size via Content-Range
                const testRes = await fetch(proxyUrl, {
                    headers: { Range: "bytes=0-0" },
                });

                if (!testRes.ok) {
                    throw new Error(
                        `Failed to initialize stream download: ${testRes.status}`,
                    );
                }

                const contentRange = testRes.headers.get("Content-Range");
                let totalSize = 0;
                if (contentRange) {
                    const parts = contentRange.split("/");
                    if (parts.length > 1) {
                        totalSize = parseInt(parts[1]);
                    }
                }

                if (!totalSize) {
                    const cl = testRes.headers.get("Content-Length");
                    totalSize = cl ? parseInt(cl) : 0;
                }

                if (!totalSize) {
                    // Fallback to direct download
                    window.location.href = `${API_BASE}/api/download/${track.id}?title=${encodeURIComponent(track.title)}`;
                    updateDownloadProgress("Downloading...", false);
                    return;
                }

                console.log(
                    `[Chunk Downloader] Total size: ${totalSize} bytes`,
                );

                // 2.5 MB chunk size (staying safely below Vercel's 4.5MB limit)
                const chunkSize = 2.5 * 1024 * 1024;
                const blobs = [];
                let start = 0;

                while (start < totalSize) {
                    const end = Math.min(start + chunkSize - 1, totalSize - 1);
                    const progress = Math.round((start / totalSize) * 100);
                    updateDownloadProgress(`Downloading: ${progress}%`, true);
                    console.log(
                        `[Chunk Downloader] Fetching range: ${start}-${end}`,
                    );

                    const chunkRes = await fetch(proxyUrl, {
                        headers: { Range: `bytes=${start}-${end}` },
                    });

                    if (!chunkRes.ok) {
                        throw new Error(
                            `Failed to download audio chunk: ${chunkRes.status}`,
                        );
                    }

                    const blob = await chunkRes.blob();
                    blobs.push(blob);
                    start += chunkSize;
                }

                updateDownloadProgress("Saving...", true);

                const finalBlob = new Blob(blobs, { type: "audio/mpeg" });
                const downloadUrl = URL.createObjectURL(finalBlob);

                const link = document.createElement("a");
                link.href = downloadUrl;
                link.download = `${track.title}.mp3`;
                document.body.appendChild(link);
                link.click();

                document.body.removeChild(link);
                URL.revokeObjectURL(downloadUrl);
                updateDownloadProgress("Download complete", false);
                console.log("[Chunk Downloader] Download complete!");
            } catch (err) {
                console.error("[Chunk Downloader] Download failed:", err);
                updateDownloadProgress("Failed", false);
                window.location.href = `${API_BASE}/api/download/${track.id}?title=${encodeURIComponent(track.title)}`;
            }
        };

        const miniDownloadBtn = document.getElementById("mini-download-btn");
        if (miniDownloadBtn && !miniDownloadBtn.dataset.bound) {
            miniDownloadBtn.dataset.bound = "true";
            miniDownloadBtn.addEventListener("click", (e) => {
                e.stopPropagation();
                handleDownload();
            });
        }

        const mobDownloadBtn = document.getElementById("mobile-mini-download");
        if (mobDownloadBtn && !mobDownloadBtn.dataset.bound) {
            mobDownloadBtn.dataset.bound = "true";
            mobDownloadBtn.addEventListener("click", (e) => {
                e.stopPropagation();
                handleDownload();
            });
        }

        const immDownloadBtn = document.getElementById(
            "immersive-download-btn",
        );
        if (immDownloadBtn && !immDownloadBtn.dataset.bound) {
            immDownloadBtn.dataset.bound = "true";
            immDownloadBtn.addEventListener("click", handleDownload);
        }

        // Progress Seeking with Drag & Touch Support
        const bindProgressContainer = (containerId: string) => {
            const container = document.getElementById(containerId);
            if (container && !container.dataset.bound) {
                container.dataset.bound = "true";

                let isDragging = false;

                const seekToPos = (clientX: number) => {
                    const rect = container.getBoundingClientRect();
                    const pos = Math.max(
                        0,
                        Math.min(1, (clientX - rect.left) / rect.width),
                    );

                    const progressBar = document.getElementById("progress-bar");
                    const progressHandle =
                        document.getElementById("progress-handle");
                    const mobProgressBar = document.getElementById(
                        "mobile-progress-bar",
                    );
                    const mobProgressHandle = document.getElementById(
                        "mobile-progress-handle",
                    );
                    const immProgressBar = document.getElementById(
                        "immersive-progress-bar",
                    );
                    const immProgressHandle = document.getElementById(
                        "immersive-progress-handle",
                    );
                    if (progressBar) progressBar.style.width = `${pos * 100}%`;
                    if (progressHandle)
                        progressHandle.style.left = `${pos * 100}%`;
                    if (mobProgressBar)
                        mobProgressBar.style.width = `${pos * 100}%`;
                    if (mobProgressHandle)
                        mobProgressHandle.style.left = `${pos * 100}%`;
                    if (immProgressBar)
                        immProgressBar.style.width = `${pos * 100}%`;
                    if (immProgressHandle)
                        immProgressHandle.style.left = `${pos * 100}%`;

                    const duration = getDuration();
                    if (duration > 0) {
                        const currentTime = pos * duration;
                        const currentTimeEl =
                            document.getElementById("current-time");
                        const immCurrentTimeEl = document.getElementById(
                            "immersive-current-time",
                        );
                        if (currentTimeEl)
                            currentTimeEl.textContent = formatTime(currentTime);
                        if (immCurrentTimeEl)
                            immCurrentTimeEl.textContent =
                                formatTime(currentTime);

                        audio.currentTime = currentTime;
                        updateActiveLyric(currentTime); // Smoothly update active lyric scrolling during drag seeking!
                    }
                };

                container.addEventListener("mousedown", (e) => {
                    isDragging = true;
                    seekToPos(e.clientX);
                });

                window.addEventListener("mousemove", (e) => {
                    if (isDragging) seekToPos(e.clientX);
                });

                window.addEventListener("mouseup", () => {
                    isDragging = false;
                });

                // Touch support for phones
                container.addEventListener(
                    "touchstart",
                    (e) => {
                        isDragging = true;
                        seekToPos(e.touches[0].clientX);
                    },
                    { passive: true },
                );

                window.addEventListener(
                    "touchmove",
                    (e) => {
                        if (isDragging) seekToPos(e.touches[0].clientX);
                    },
                    { passive: true },
                );

                window.addEventListener("touchend", () => {
                    isDragging = false;
                });
            }
        };

        bindProgressContainer("progress-container");
        bindProgressContainer("mobile-progress-container");
        bindProgressContainer("immersive-progress-container");

        // Allow clicking the bottom player anywhere (except buttons/volume) to open immersive view on mobile
        const audioPlayerContainer = document.getElementById("audio-player");
        if (audioPlayerContainer && !audioPlayerContainer.dataset.clickBound) {
            audioPlayerContainer.dataset.clickBound = "true";
            audioPlayerContainer.addEventListener("click", (e) => {
                const target = e.target as HTMLElement;
                if (
                    target.closest("button") ||
                    target.closest("a") ||
                    target.closest("#volume-container") ||
                    target.closest("#mobile-progress-container") ||
                    target.closest("#progress-container")
                ) {
                    return;
                }
                const immPlayer = document.getElementById("immersive-player");
                if (immPlayer) {
                    immPlayer.classList.remove("translate-y-full");
                }
            });
        }

        // Volume Seek with Drag & Touch Support
        const volumeContainer = document.getElementById("volume-container");
        if (volumeContainer && !volumeContainer.dataset.bound) {
            volumeContainer.dataset.bound = "true";

            let isDraggingVolume = false;

            const setVolumeFromPos = (clientX: number) => {
                const rect = volumeContainer.getBoundingClientRect();
                const pos = Math.max(
                    0,
                    Math.min(1, (clientX - rect.left) / rect.width),
                );
                audio.volume = pos;
                const volumeBar = document.getElementById("volume-bar");
                if (volumeBar) volumeBar.style.width = `${pos * 100}%`;
            };

            volumeContainer.addEventListener("mousedown", (e) => {
                isDraggingVolume = true;
                setVolumeFromPos(e.clientX);
            });

            window.addEventListener("mousemove", (e) => {
                if (isDraggingVolume) setVolumeFromPos(e.clientX);
            });

            window.addEventListener("mouseup", () => {
                isDraggingVolume = false;
            });

            volumeContainer.addEventListener(
                "touchstart",
                (e) => {
                    isDraggingVolume = true;
                    setVolumeFromPos(e.touches[0].clientX);
                },
                { passive: true },
            );

            window.addEventListener(
                "touchmove",
                (e) => {
                    if (isDraggingVolume)
                        setVolumeFromPos(e.touches[0].clientX);
                },
                { passive: true },
            );

            window.addEventListener("touchend", () => {
                isDraggingVolume = false;
            });
        }

        // Overlay Toggle triggers
        const mInfo = document.getElementById("mini-info");
        if (mInfo && !mInfo.dataset.bound) {
            mInfo.dataset.bound = "true";
            mInfo.addEventListener("click", () => {
                toggleImmersive();
                switchTab(state.activeTab);
            });
        }

        const toggleImmBtn = document.getElementById("toggle-immersive-btn");
        if (toggleImmBtn && !toggleImmBtn.dataset.bound) {
            toggleImmBtn.dataset.bound = "true";
            toggleImmBtn.addEventListener("click", () => {
                toggleImmersive();
                switchTab(state.activeTab);
            });
        }

        const closeImm = document.getElementById("close-immersive");
        if (closeImm && !closeImm.dataset.bound) {
            closeImm.dataset.bound = "true";
            closeImm.addEventListener("click", toggleImmersive);
        }

        // Tab selection switcher in full overlay
        const tQueue = document.getElementById("tab-queue");
        const tLyrics = document.getElementById("tab-lyrics");
        const tRelated = document.getElementById("tab-related");
        const qContent = document.getElementById("queue-content");
        const lyrContent = document.getElementById("lyrics-content");
        const relContent = document.getElementById("related-content");

        const switchTab = (activeTab: string) => {
            state.activeTab = activeTab;
            [tQueue, tLyrics, tRelated].forEach((t) => {
                t?.classList.remove(
                    "bg-primary/5",
                    "border-primary",
                    "text-white",
                );
                t?.classList.add("text-white/60", "border-transparent");
            });
            [qContent, lyrContent, relContent].forEach((c) =>
                c?.classList.add("hidden"),
            );

            const leftCol = document.getElementById("immersive-left-column");
            const rightCol = document.getElementById("immersive-right-column");

            // Responsive wrapper: keep columns visible and let them stack vertically on mobile (flex-col) and side-by-side on desktop (lg:flex-row)
            leftCol?.classList.remove("hidden");
            leftCol?.classList.add("flex");
            rightCol?.classList.remove("hidden");
            rightCol?.classList.add("flex");

            if (activeTab === "queue") {
                tQueue?.classList.add(
                    "bg-primary/5",
                    "border-primary",
                    "text-white",
                );
                tQueue?.classList.remove("text-white/60", "border-transparent");
                qContent?.classList.remove("hidden");
                updateQueueUI();
            } else if (activeTab === "lyrics") {
                tLyrics?.classList.add(
                    "bg-primary/5",
                    "border-primary",
                    "text-white",
                );
                tLyrics?.classList.remove(
                    "text-white/60",
                    "border-transparent",
                );
                lyrContent?.classList.remove("hidden");
                if (
                    state.currentIndex !== -1 &&
                    state.currentQueue[state.currentIndex]
                ) {
                    updateLyrics(state.currentQueue[state.currentIndex].id);
                }
            } else if (activeTab === "related") {
                tRelated?.classList.add(
                    "bg-primary/5",
                    "border-primary",
                    "text-white",
                );
                tRelated?.classList.remove(
                    "text-white/60",
                    "border-transparent",
                );
                relContent?.classList.remove("hidden");
                if (
                    state.currentIndex !== -1 &&
                    state.currentQueue[state.currentIndex]
                ) {
                    updateRelatedUI(state.currentQueue[state.currentIndex].id);
                }
            }
        };

        if (tQueue && !tQueue.dataset.bound) {
            tQueue.dataset.bound = "true";
            tQueue.addEventListener("click", () => switchTab("queue"));
        }
        if (tLyrics && !tLyrics.dataset.bound) {
            tLyrics.dataset.bound = "true";
            tLyrics.addEventListener("click", () => switchTab("lyrics"));
        }
        if (tRelated && !tRelated.dataset.bound) {
            tRelated.dataset.bound = "true";
            tRelated.addEventListener("click", () => switchTab("related"));
        }

        // Remove old listeners to prevent multiple bindings during page swaps
        if ((window as any).playTrackListener) {
            window.removeEventListener(
                "play-track",
                (window as any).playTrackListener,
            );
        }
        if ((window as any).addToQueueListener) {
            window.removeEventListener(
                "add-to-queue",
                (window as any).addToQueueListener,
            );
        }

        // Define and bind new listeners for this page load
        (window as any).playTrackListener = async (e: CustomEvent) => {
            const track = e.detail;
            const existingIdx = state.currentQueue.findIndex(
                (t: any) => t.id === track.id,
            );
            if (existingIdx === -1) {
                state.currentQueue.push(track);
                state.currentIndex = state.currentQueue.length - 1;
            } else {
                state.currentIndex = existingIdx;
            }
            if (state.isShuffle) {
                if (!state.originalQueue.some((t: any) => t.id === track.id)) {
                    state.originalQueue.push(track);
                }
            }
            fetchStreamAndPlay(state.currentQueue[state.currentIndex]);
        };

        (window as any).addToQueueListener = (e: CustomEvent) => {
            const track = e.detail;
            if (!state.currentQueue.find((t: any) => t.id === track.id)) {
                state.currentQueue.push(track);
                if (state.isShuffle) {
                    state.originalQueue.push(track);
                }
                updateQueueUI();
                miniPlayer?.classList.remove("translate-y-full");
                saveState();
            }
        };

        window.addEventListener(
            "play-track",
            (window as any).playTrackListener as any,
        );
        window.addEventListener(
            "add-to-queue",
            (window as any).addToQueueListener as any,
        );

        // Unified Document Click Delegation for dynamically rendered song triggers and playlist routing
        if (!(document as any).clickBound) {
            (document as any).clickBound = true;
            document.addEventListener("click", (e) => {
                const target = e.target as HTMLElement;

                // Playlist click routing
                const plTrigger = target.closest(".playlist-trigger");
                if (plTrigger) {
                    const id = (plTrigger as HTMLElement).dataset.id;
                    navigate(`/playlist?id=${id}`);
                    return;
                }

                // Add to queue trigger
                const queueBtn = target.closest(".queue-add");
                if (queueBtn) {
                    e.stopPropagation();
                    const track = queueBtn.closest(
                        ".track-trigger",
                    ) as HTMLElement;
                    window.dispatchEvent(
                        new CustomEvent("add-to-queue", {
                            detail: { ...track.dataset },
                        }),
                    );
                    return;
                }

                // Play track trigger
                const trigger = target.closest(".track-trigger");
                if (trigger) {
                    syncUnlockAudio();
                    const { id, title, artist, artwork } = (
                        trigger as HTMLElement
                    ).dataset;
                    window.dispatchEvent(
                        new CustomEvent("play-track", {
                            detail: {
                                id,
                                title,
                                artist,
                                artwork,
                                image: artwork,
                            },
                        }),
                    );
                }
            });
        }

        loadState();
    }

    document.addEventListener("astro:page-load", initPlayer);
</script>

<style>
    .animate-spin-slow {
        animation: spin 12s linear infinite;
    }
    .paused {
        animation-play-state: paused;
    }
    .running {
        animation-play-state: running;
    }
    @keyframes spin {
        from {
            transform: rotate(0deg);
        }
        to {
            transform: rotate(360deg);
        }
    }
    .scrollbar-hide::-webkit-scrollbar {
        display: none;
    }

    /* Responsive position override for mobile viewports above BottomNav */
    @media (max-width: 1279px) {
        #audio-player {
            bottom: calc(4.5rem + env(safe-area-inset-bottom, 0px)) !important;
        }
    }
</style>
