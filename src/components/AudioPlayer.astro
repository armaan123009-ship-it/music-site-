---
import {
    Play,
    Pause,
    SkipBack,
    SkipForward,
    Volume2,
    Repeat,
    Shuffle,
    ListMusic,
    ChevronUp,
    Sparkles,
    MoreVertical,
    Download,
} from "lucide-react";
---

<div
    id="persistent-audio-player-root"
    transition:persist
    style="display: contents;"
>
    <!-- Full Screen Immersive Player Overlay -->
    <div
        id="immersive-player"
        class="fixed inset-0 z-[60] bg-background/95 backdrop-blur-3xl transition-all duration-700 translate-y-full flex flex-col p-6 overflow-y-auto scrollbar-hide"
    >
        <!-- Top Bar -->
        <div
            class="flex items-center justify-between w-full max-w-7xl mx-auto z-20"
        >
            <button
                id="close-immersive"
                class="p-2.5 hover:bg-white/5 rounded-full transition-all text-white cursor-pointer"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="w-6 h-6"><path d="m6 9 6 6 6-6"></path></svg
                >
            </button>
            <span
                class="text-xs font-black uppercase tracking-widest text-muted-foreground text-center flex-1"
                >Now Playing</span
            >
            <button
                class="p-2.5 hover:bg-white/5 rounded-full transition-all text-white cursor-pointer"
            >
                <MoreVertical className="w-5 h-5 text-muted-foreground" />
            </button>
        </div>

        <!-- Center Content -->
        <div
            id="immersive-center-content"
            class="flex-1 flex flex-col lg:flex-row items-center justify-center gap-8 lg:gap-16 max-w-7xl mx-auto w-full h-full mt-6 lg:mt-0"
        >
            <!-- Left Column: Artwork, Info, Slider, Controls -->
            <div
                id="immersive-left-column"
                class="w-full lg:w-1/2 flex flex-col items-center justify-center text-center space-y-6 md:space-y-8 shrink-0 max-w-md mx-auto"
            >
                <!-- Glowing Artwork Container -->
                <div
                    class="relative w-64 h-64 sm:w-72 sm:h-72 md:w-80 md:h-80 lg:w-96 lg:h-96 group mx-auto"
                >
                    <!-- Outer Glow Layer -->
                    <div
                        id="immersive-artwork-glow"
                        class="absolute inset-0 opacity-60 rounded-[2.5rem] blur-[35px] pointer-events-none transition-all duration-500"
                        style="background: linear-gradient(137deg, var(--primary) 0%, #7c7c7c 100%)"
                    >
                    </div>
                    <!-- Foreground Image -->
                    <div
                        class="relative w-full h-full rounded-[2.5rem] overflow-hidden shadow-[0_0_80px_rgba(0,0,0,0.5)] border border-white/10 z-10 bg-card"
                    >
                        <img
                            id="immersive-artwork"
                            referrerpolicy="no-referrer"
                            src=""
                            alt="Artwork"
                            class="w-full h-full object-cover transition-opacity duration-500 opacity-0"
                            onload="this.classList.remove('opacity-0')"
                            onerror="this.onerror=null; if(this.dataset.id) { this.src='https://i.ytimg.com/vi/' + this.dataset.id + '/hqdefault.jpg'; } else { this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'24\' height=\'24\' viewBox=\'0 0 24 24\' fill=\'none\' stroke=\'%23888\' stroke-width=\'2\'><path d=\'M9 18V5l12-2v13\'/><circle cx=\'6\' cy=\'18\' r=\'3\'/><circle cx=\'18\' cy=\'16\' r=\'3\'/></svg>'; this.style.padding='24%'; this.style.backgroundColor='#18181b'; }"
                        />
                        <div
                            class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent pointer-events-none z-10"
                        >
                        </div>
                    </div>
                </div>

                <!-- Title, Artist, and Like/Download Button -->
                <div
                    class="flex items-center justify-between w-full px-2 gap-4"
                >
                    <div class="flex-1 text-left min-w-0">
                        <h1
                            id="immersive-title"
                            class="text-2xl md:text-3xl font-black tracking-tight text-white truncate"
                        >
                            Select a track
                        </h1>
                        <p
                            id="immersive-artist"
                            class="text-sm md:text-base text-primary font-bold truncate"
                        >
                            Premium Artist
                        </p>
                    </div>
                    <div class="flex items-center gap-2 shrink-0">
                        <!-- Download option -->
                        <button
                            id="immersive-download-btn"
                            class="p-3 bg-white/5 hover:bg-white/10 border border-white/5 rounded-full transition-all text-muted-foreground group shrink-0 cursor-pointer"
                            title="Download track"
                        >
                            <Download className="w-5 h-5 text-white" />
                        </button>
                        <!-- Like option -->
                        <button
                            id="immersive-like-btn"
                            class="p-3 bg-white/5 hover:bg-white/10 border border-white/5 rounded-full transition-all text-muted-foreground group shrink-0 cursor-pointer"
                        >
                            <svg
                                id="immersive-like-icon"
                                xmlns="http://www.w3.org/2000/svg"
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                class="transition-all group-active:scale-125"
                                ><path
                                    d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"
                                ></path></svg
                            >
                        </button>
                    </div>
                </div>

                <!-- Progress Bar Slider -->
                <div class="w-full px-2 space-y-2">
                    <div
                        class="group relative w-full h-1.5 bg-white/10 rounded-full cursor-pointer"
                        id="immersive-progress-container"
                    >
                        <div
                            id="immersive-progress-bar"
                            class="absolute top-0 left-0 h-full bg-primary rounded-full transition-all duration-100 ease-linear"
                            style="width: 0%"
                        >
                        </div>
                        <div
                            id="immersive-progress-handle"
                            class="absolute top-1/2 -translate-y-1/2 -ml-1.5 w-3.5 h-3.5 bg-white border border-primary rounded-full opacity-0 group-hover:opacity-100 transition-opacity shadow-md pointer-events-none"
                            style="left: 0%"
                        >
                        </div>
                    </div>
                    <div
                        class="flex justify-between text-[10px] font-bold text-muted-foreground/80 tracking-wider"
                    >
                        <span id="immersive-current-time">0:00</span>
                        <span id="immersive-duration">0:00</span>
                    </div>
                </div>

                <!-- Controls Row -->
                <div
                    class="flex items-center justify-between w-full px-4 max-w-sm mx-auto"
                >
                    <button
                        id="immersive-shuffle-btn"
                        class="text-muted-foreground hover:text-foreground transition-colors p-2 rounded-full hover:bg-white/5 cursor-pointer"
                        title="Shuffle"
                    >
                        <Shuffle className="w-5 h-5" />
                    </button>
                    <button
                        id="immersive-prev-btn"
                        class="text-white hover:scale-110 transition-transform p-2 cursor-pointer"
                    >
                        <SkipBack className="w-6 h-6 fill-current text-white" />
                    </button>
                    <!-- Play/Pause Button -->
                    <button
                        id="immersive-play-pause-btn"
                        class="w-14 h-14 md:w-16 md:h-16 rounded-full bg-primary text-primary-foreground flex items-center justify-center hover:scale-105 active:scale-95 transition-all shadow-xl shadow-primary/20 shrink-0 cursor-pointer"
                    >
                        <Play
                            id="immersive-play-icon"
                            className="w-6 h-6 md:w-7 md:h-7 fill-current text-primary-foreground"
                        />
                        <Pause
                            id="immersive-pause-icon"
                            className="w-6 h-6 md:w-7 md:h-7 fill-current hidden text-primary-foreground"
                        />
                    </button>
                    <button
                        id="immersive-next-btn"
                        class="text-white hover:scale-110 transition-transform p-2 cursor-pointer"
                    >
                        <SkipForward
                            className="w-6 h-6 fill-current text-white"
                        />
                    </button>
                    <button
                        id="immersive-repeat-btn"
                        class="text-muted-foreground hover:text-foreground transition-colors p-2 rounded-full hover:bg-white/5 cursor-pointer"
                        title="Repeat"
                    >
                        <Repeat className="w-5 h-5" />
                    </button>
                </div>
            </div>

            <!-- Right Column: Tabs Section (Lyrics / Queue / Related) -->
            <div
                id="immersive-right-column"
                class="w-full lg:w-1/2 flex flex-col h-[380px] lg:h-[520px] bg-muted/5 rounded-[2rem] border border-white/5 overflow-hidden"
            >
                <div class="flex border-b border-white/5 bg-[#121214]">
                    <button
                        id="tab-queue"
                        class="flex-1 py-4 text-xs font-bold border-b-2 border-primary bg-primary/5 transition-all flex items-center justify-center gap-2 text-white cursor-pointer"
                    >
                        Up next
                    </button>
                    <button
                        id="tab-lyrics"
                        class="flex-1 py-4 text-xs font-bold border-b-2 border-transparent hover:bg-white/5 transition-all flex items-center justify-center gap-2 text-white/60 cursor-pointer"
                    >
                        Lyrics
                    </button>
                    <button
                        id="tab-related"
                        class="flex-1 py-4 text-xs font-bold border-b-2 border-transparent hover:bg-white/5 transition-all flex items-center justify-center gap-2 text-white/60 cursor-pointer"
                    >
                        Related
                    </button>
                </div>

                <div class="flex-1 overflow-y-auto p-5 relative scrollbar-hide">
                    <!-- Up Next Queue Content -->
                    <div id="queue-content" class="space-y-4">
                        <div
                            class="flex items-center justify-between pb-3 border-b border-white/5 mb-2 sticky top-0 bg-background/95 backdrop-blur-md z-10"
                        >
                            <span
                                class="text-xs font-bold text-white/80 uppercase tracking-widest"
                                >Queue list</span
                            >
                            <label
                                class="relative inline-flex items-center cursor-pointer select-none"
                            >
                                <input
                                    type="checkbox"
                                    id="autoplay-toggle"
                                    class="sr-only peer"
                                    checked
                                />
                                <div
                                    class="w-8 h-4.5 bg-white/10 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-3.5 after:w-3.5 after:transition-all peer-checked:bg-primary"
                                >
                                </div>
                                <span
                                    class="ms-2 text-xs font-bold text-white/80"
                                    >Autoplay</span
                                >
                            </label>
                        </div>
                        <div id="queue-list-container" class="space-y-1.5">
                            <!-- Queue items -->
                        </div>
                    </div>

                    <!-- Lyrics Content -->
                    <div
                        id="lyrics-content"
                        class="hidden text-base md:text-lg font-medium leading-relaxed text-white/80 space-y-4 text-center"
                    >
                        <p class="opacity-50 italic">
                            Select a track to see lyrics...
                        </p>
                    </div>

                    <!-- Related Content -->
                    <div id="related-content" class="hidden space-y-4">
                        <div
                            class="flex items-center justify-between pb-3 border-b border-white/5 mb-2 sticky top-0 bg-background/95 backdrop-blur-md z-10"
                        >
                            <span
                                class="text-xs font-bold text-white/80 uppercase tracking-widest"
                                >Recommended tracks</span
                            >
                        </div>
                        <div id="related-list-container" class="space-y-1.5">
                            <!-- Related items -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bottom Mini Player -->
    <div
        id="audio-player"
        class="fixed bottom-0 left-0 right-0 z-40 bg-background/90 backdrop-blur-xl border-t border-border/40 p-3.5 transition-transform duration-500 translate-y-full"
    >
        <div class="max-w-7xl mx-auto flex items-center justify-between gap-4">
            <!-- Track Info -->
            <div
                id="mini-info"
                class="flex items-center gap-3 w-[70%] sm:w-1/3 cursor-pointer group min-w-0"
            >
                <div
                    class="relative w-11 h-11 rounded-lg overflow-hidden border border-border shrink-0"
                >
                    <img
                        id="player-artwork"
                        referrerpolicy="no-referrer"
                        src=""
                        alt="Artwork"
                        class="w-full h-full object-cover animate-spin-slow paused group-[.playing]:running transition-opacity duration-500 opacity-0"
                        onload="this.classList.remove('opacity-0')"
                        onerror="this.onerror=null; if(this.dataset.id) { this.src='https://i.ytimg.com/vi/' + this.dataset.id + '/hqdefault.jpg'; } else { this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'24\' height=\'24\' viewBox=\'0 0 24 24\' fill=\'none\' stroke=\'%23888\' stroke-width=\'2\'><path d=\'M9 18V5l12-2v13\'/><circle cx=\'6\' cy=\'18\' r=\'3\'/><circle cx=\'18\' cy=\'16\' r=\'3\'/></svg>'; this.style.padding='20%'; this.style.backgroundColor='#18181b'; }"
                    />
                    <div
                        class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"
                    >
                        <ChevronUp className="w-4 h-4 text-white" />
                    </div>
                </div>
                <div class="flex flex-col overflow-hidden min-w-0">
                    <span
                        id="player-title"
                        class="text-sm font-bold truncate text-white"
                        >Select a track</span
                    >
                    <span
                        id="player-artist"
                        class="text-xs text-muted-foreground truncate"
                        >Premium Music</span
                    >
                </div>
            </div>

            <!-- Controls (Center on Desktop) -->
            <div class="hidden md:flex flex-col items-center gap-1.5 w-1/3">
                <div class="flex items-center gap-5">
                    <button
                        id="shuffle-btn"
                        class="text-muted-foreground hover:text-foreground transition-colors relative p-1.5 rounded-full hover:bg-white/5 cursor-pointer"
                        title="Shuffle"><Shuffle className="w-4 h-4" /></button
                    >
                    <button
                        id="prev-btn"
                        class="text-foreground hover:scale-110 transition-transform p-1 cursor-pointer"
                        ><SkipBack
                            className="w-4.5 h-4.5 fill-current text-white"
                        /></button
                    >
                    <button
                        id="play-pause-btn"
                        class="w-9 h-9 rounded-full bg-primary text-primary-foreground flex items-center justify-center hover:scale-105 active:scale-95 transition-all shadow-lg shadow-primary/20 shrink-0 cursor-pointer"
                    >
                        <Play
                            id="play-icon"
                            className="w-4.5 h-4.5 fill-current text-primary-foreground"
                        />
                        <Pause
                            id="pause-icon"
                            className="w-4.5 h-4.5 fill-current hidden text-primary-foreground"
                        />
                    </button>
                    <button
                        id="next-btn"
                        class="text-foreground hover:scale-110 transition-transform p-1 cursor-pointer"
                        ><SkipForward
                            className="w-4.5 h-4.5 fill-current text-white"
                        /></button
                    >
                    <button
                        id="repeat-btn"
                        class="text-muted-foreground hover:text-foreground transition-colors relative p-1.5 rounded-full hover:bg-white/5 cursor-pointer"
                        title="Repeat"><Repeat className="w-4 h-4" /></button
                    >
                    <button
                        id="autoplay-btn"
                        class="text-muted-foreground hover:text-foreground transition-colors relative p-1.5 rounded-full hover:bg-white/5 cursor-pointer"
                        title="Autoplay recommendations"
                        ><Sparkles className="w-4 h-4" /></button
                    >
                </div>

                <div class="flex items-center gap-3 w-full max-w-md">
                    <span
                        id="current-time"
                        class="text-[10px] tabular-nums text-muted-foreground w-10 text-right"
                        >0:00</span
                    >
                    <div
                        class="group relative flex-1 h-1 bg-white/10 rounded-full cursor-pointer"
                        id="progress-container"
                    >
                        <div
                            id="progress-bar"
                            class="absolute top-0 left-0 h-full bg-primary rounded-full transition-all duration-100 ease-linear"
                            style="width: 0%"
                        >
                        </div>
                        <div
                            id="progress-handle"
                            class="absolute top-1/2 -translate-y-1/2 -ml-1.5 w-3 h-3 bg-white border border-primary rounded-full opacity-0 group-hover:opacity-100 transition-opacity shadow-md pointer-events-none"
                            style="left: 0%"
                        >
                        </div>
                    </div>
                    <span
                        id="duration"
                        class="text-[10px] tabular-nums text-muted-foreground w-10"
                        >0:00</span
                    >
                </div>
            </div>

            <!-- Mobile Controls (Download + Play/Pause + Next) -->
            <div class="flex items-center gap-2 md:hidden shrink-0 z-10">
                <button
                    id="mobile-mini-download"
                    class="p-2 text-white/70 hover:text-white cursor-pointer"
                    title="Download song"
                >
                    <Download className="w-5.5 h-5.5 text-white" />
                </button>
                <button
                    id="mobile-mini-play-pause"
                    class="p-2 text-white transition-all cursor-pointer"
                >
                    <Play
                        id="mobile-play-icon"
                        className="w-6 h-6 fill-current text-white"
                    />
                    <Pause
                        id="mobile-pause-icon"
                        className="w-6 h-6 fill-current hidden text-white"
                    />
                </button>
                <button
                    id="mobile-mini-next"
                    class="p-2 text-white cursor-pointer"
                >
                    <SkipForward className="w-6 h-6 fill-current text-white" />
                </button>
            </div>

            <!-- Volume & Actions -->
            <div class="hidden md:flex items-center justify-end gap-5 w-1/3">
                <!-- Download Button -->
                <button
                    id="mini-download-btn"
                    class="p-2 hover:bg-white/10 rounded-full transition-all text-muted-foreground group cursor-pointer"
                    title="Download song"
                >
                    <Download className="w-4.5 h-4.5 text-white" />
                </button>
                <!-- Like Button -->
                <button
                    id="mini-like-btn"
                    class="p-2 hover:bg-white/10 rounded-full transition-all text-muted-foreground group cursor-pointer"
                >
                    <svg
                        id="mini-like-icon"
                        xmlns="http://www.w3.org/2000/svg"
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="transition-all group-active:scale-125"
                        ><path
                            d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"
                        ></path></svg
                    >
                </button>
                <div class="flex items-center gap-2">
                    <Volume2 className="w-4 h-4 text-muted-foreground" />
                    <div
                        id="volume-container"
                        class="w-20 h-1 bg-muted rounded-full cursor-pointer relative overflow-hidden group"
                    >
                        <div
                            id="volume-bar"
                            class="absolute top-0 left-0 h-full bg-foreground"
                            style="width: 80%"
                        >
                        </div>
                    </div>
                </div>
                <button
                    id="toggle-immersive-btn"
                    class="p-2 hover:bg-white/5 rounded-full transition-all shrink-0 cursor-pointer"
                >
                    <ListMusic className="w-4.5 h-4.5 text-white" />
                </button>
            </div>
        </div>

        <!-- Progress Bar for Mobile (Top of Mini Player) -->
        <div
            class="absolute top-0 left-0 right-0 h-1 bg-white/10 md:hidden cursor-pointer group"
            id="mobile-progress-container"
        >
            <div
                id="mobile-progress-bar"
                class="h-full bg-primary rounded-full transition-all duration-100 ease-linear"
                style="width: 0%"
            >
            </div>
            <div
                id="mobile-progress-handle"
                class="absolute top-1/2 -translate-y-1/2 -ml-1.5 w-3 h-3 bg-white border border-primary rounded-full opacity-0 group-hover:opacity-100 transition-opacity shadow-md pointer-events-none"
                style="left: 0%"
            >
            </div>
        </div>
    </div>

    <audio id="main-audio" preload="auto"></audio>
</div>

<script>
    import {
        fetchLyrics,
        fetchSuggestions,
        getStreamProxyUrl,
        toggleLike,
        getUserData,
        apiFetch,
        API_BASE,
    } from "../lib/api";
    import { navigate } from "astro:transitions/client";

    // Premium gradients for background glows
    const GLOW_GRADIENTS = [
        "linear-gradient(137deg, var(--primary) 0%, #7c7c7c 100%)",
        "linear-gradient(137deg, var(--primary) 0%, #1e1e1e 100%)",
        "linear-gradient(137deg, var(--primary) 0%, #000000 100%)",
    ];

    function getGlowGradient(title: string) {
        if (!title) return GLOW_GRADIENTS[0];
        let hash = 0;
        for (let i = 0; i < title.length; i++) {
            hash = title.charCodeAt(i) + ((hash << 5) - hash);
        }
        const idx = Math.abs(hash) % GLOW_GRADIENTS.length;
        return GLOW_GRADIENTS[idx];
    }

    // Initialize or reuse persistent player state on the window object
    const state = (window as any).playerState || {
        isPlaying: false,
        currentQueue: [],
        originalQueue: [],
        currentIndex: -1,
        isShuffle: false,
        repeatMode: "none", // 'none' | 'all' | 'one'
        isAutoplay: true,
        currentUser: null,
        activeTab: "queue",
        currentStreamUrl: null,
        currentProxyUrl: null,
        streamUrlCache: {},
        parsedLyrics: [],
        lastActiveLyricIdx: -1,
        isPreFetching: false,
        preFetchedTrackId: null,
    };
    (window as any).playerState = state;

    let audio: HTMLAudioElement;
    let miniPlayer: HTMLElement | null;
    let immersivePlayer: HTMLElement | null;

    function syncUnlockAudio() {
        if (audio) {
            try {
                audio.play().catch(() => {});
                audio.pause();
            } catch (e) {}
        }
    }

    // Wake Lock Variables
    let wakeLock: any = null;

    async function requestWakeLock() {
        if ("wakeLock" in navigator) {
            try {
                if (!wakeLock) {
                    wakeLock = await (navigator as any).wakeLock.request(
                        "screen",
                    );
                    console.log("[Wake Lock] Screen Wake Lock acquired");
                }
            } catch (err: any) {
                console.warn(
                    `[Wake Lock] Failed to acquire screen wake lock: ${err.name}, ${err.message}`,
                );
            }
        }
    }

    function releaseWakeLock() {
        if (wakeLock) {
            try {
                wakeLock.release().then(() => {
                    wakeLock = null;
                    console.log("[Wake Lock] Screen Wake Lock released");
                });
            } catch (e) {
                wakeLock = null;
            }
        }
    }

    async function resolveStreamClientSide(trackId: string): Promise<{ streamUrl: string; proxyUrl: string } | null> {
        console.log(`[Client Resolver] Resolving stream for ${trackId}...`);

        // 1. Try client-side Cobalt fallback across multiple instances and schemas (v7, v10, minimal)
        const cobaltInstances = [
            "https://rue-cobalt.xenon.zone",
            "https://api.cobalt.tools",
            "https://cobalt.foxtrot-omega.me",
            "https://cobalt.willy.lol",
            "https://cobalt.k6.dev",
            "https://cobalt-api.lunar.icu",
            "https://cobalt.col1g3.de",
            "https://cobalt.projectsegfau.lt",
        ];
        const schemas = [
            { downloadMode: "audio", audioFormat: "mp3" },
            { audioOnly: true, aFormat: "mp3" },
            { audioOnly: true, audioFormat: "mp3" },
            {} // Minimalist video fallback
        ];

        for (const instance of cobaltInstances) {
            for (const schemaOption of schemas) {
                try {
                    const bodyData = {
                        url: `https://www.youtube.com/watch?v=${trackId}`,
                        ...schemaOption
                    };
                    const cobaltRes = await fetch(
                        instance.endsWith("/") ? instance : `${instance}/`,
                        {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json",
                                Accept: "application/json",
                            },
                            body: JSON.stringify(bodyData),
                        },
                    );
                    if (cobaltRes.ok) {
                        const cobaltData = await cobaltRes.json();
                        const sUrl = cobaltData.url || cobaltData.picker;
                        if (sUrl) {
                            console.log(
                                `[Client Resolver] Successfully resolved stream via Cobalt on: ${instance} using schema:`,
                                schemaOption
                            );
                            return { streamUrl: sUrl, proxyUrl: sUrl };
                        }
                    }
                } catch (cobaltErr) {
                    // Fail silently and try next schema/instance
                }
            }
        }

        // 2. Try client-side Piped fallback across multiple instances
        const pipedInstances = [
            "https://api-piped.mha.fi",
            "https://api.piped.private.coffee",
            "https://pipedapi.kavin.rocks",
            "https://pipedapi.col1g3.de",
            "https://piped-api.garudalinux.org",
            "https://pipedapi.us.to",
            "https://api.piped.projectsegfau.lt",
            "https://pipedapi.privacydev.net",
            "https://pipedapi.lunar.icu",
        ];
        for (const instance of pipedInstances) {
            try {
                const pipedRes = await fetch(
                    `${instance}/streams/${trackId}`,
                );
                if (pipedRes.ok) {
                    const pipedData = await pipedRes.json();
                    const audioStreams = pipedData.audioStreams || [];
                    if (audioStreams.length > 0 && audioStreams[0].url) {
                        const sUrl = audioStreams[0].url;
                        console.log(
                            `[Client Resolver] Successfully resolved stream via Piped on: ${instance}`,
                        );
                        return { streamUrl: sUrl, proxyUrl: sUrl };
                    }
                }
            } catch (pipedErr) {
                console.warn(
                    `[Client Resolver] Piped instance ${instance} failed:`,
                    pipedErr,
                );
            }
        }

        return null;
    }

    // Parse duration strings like "3:45", "1:02:15", or seconds "225"
    function parseDurationStringToSeconds(durationStr: string): number {
        if (!durationStr) return 0;
        const parts = durationStr.split(":").map(Number);
        if (parts.some(isNaN)) return 0;
        if (parts.length === 3) {
            // hh:mm:ss
            return parts[0] * 3600 + parts[1] * 60 + parts[2];
        } else if (parts.length === 2) {
            // mm:ss
            return parts[0] * 60 + parts[1];
        } else if (parts.length === 1) {
            return parts[0];
        }
        return 0;
    }

    function getDuration(): number {
        if (
            audio &&
            isFinite(audio.duration) &&
            !isNaN(audio.duration) &&
            audio.duration > 0
        ) {
            return audio.duration;
        }
        if (
            state.currentIndex !== -1 &&
            state.currentQueue[state.currentIndex]
        ) {
            const track = state.currentQueue[state.currentIndex];
            if (track.duration) {
                const secs = parseDurationStringToSeconds(track.duration);
                if (secs > 0) return secs;
            }
        }
        return 0;
    }

    // LRC Parser implementation
    interface LyricLine {
        time: number;
        text: string;
    }

    function parseLRC(lrcText: string): LyricLine[] {
        if (!lrcText) return [];
        const lines = lrcText.split(/\r?\n/);
        const lyrics: LyricLine[] = [];
        const timeRegex = /\[(\d+):(\d+)(?:[\.:](\d+))?\](.*)/;

        for (const line of lines) {
            const trimmed = line.trim();
            const match = timeRegex.exec(trimmed);
            if (match) {
                const minutes = parseInt(match[1], 10);
                const seconds = parseInt(match[2], 10);
                const msStr = match[3] || "0";
                const msVal = parseInt(msStr, 10);
                const fractionalSeconds = msVal / Math.pow(10, msStr.length);

                const time = minutes * 60 + seconds + fractionalSeconds;
                const text = match[4].trim();

                lyrics.push({ time, text });
            }
        }

        return lyrics.sort((a, b) => a.time - b.time);
    }

    function showToast(message: string) {
        let toast = document.getElementById("player-toast");
        if (!toast) {
            toast = document.createElement("div");
            toast.id = "player-toast";
            toast.className =
                "fixed bottom-24 left-1/2 -translate-x-1/2 z-[100] bg-zinc-900 border border-white/10 text-white text-xs font-bold px-4 py-2.5 rounded-full shadow-2xl transition-all duration-300 opacity-0 translate-y-2 pointer-events-none flex items-center gap-2";
            document.body.appendChild(toast);
        }
        toast.innerHTML = `<span class="w-1.5 h-1.5 rounded-full bg-primary animate-ping"></span><span>${message}</span>`;
        toast.classList.remove(
            "opacity-0",
            "translate-y-2",
            "pointer-events-none",
        );
        toast.classList.add("opacity-100", "translate-y-0");

        setTimeout(() => {
            toast?.classList.remove("opacity-100", "translate-y-0");
            toast?.classList.add(
                "opacity-0",
                "translate-y-2",
                "pointer-events-none",
            );
        }, 4000);
    }

