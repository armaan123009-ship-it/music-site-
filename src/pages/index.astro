---
import Layout from '../layouts/Layout.astro';
import { Play, Sparkles, Radio, ArrowRight } from 'lucide-react';

const moodFilters = ["Podcasts", "Energize", "Feel good", "Relax", "Workout", "Focus", "Romance"];
---

<Layout title="Home | Premium Music Experience" activeNav="home">
	<!-- Main Content Area -->
	<div id="main-content-area" class="p-4 sm:p-8 md:p-12 space-y-10 md:space-y-12">
			<!-- Featured listening surface -->
			<section class="relative isolate overflow-hidden rounded-[2rem] border border-white/10 bg-gradient-to-br from-primary/30 via-[#151515] to-[#060606] px-6 py-8 shadow-2xl shadow-black/30 sm:px-10 sm:py-12">
				<div class="absolute -right-20 -top-24 h-72 w-72 rounded-full bg-primary/35 blur-3xl"></div>
				<div class="absolute bottom-[-10rem] left-1/3 h-64 w-64 rounded-full bg-orange-300/15 blur-3xl"></div>
				<div class="relative grid gap-8 lg:grid-cols-[1fr_auto] lg:items-end">
					<div class="max-w-2xl">
						<p class="mb-4 flex items-center gap-2 text-[10px] font-black uppercase tracking-[0.24em] text-primary-foreground/80"><Sparkles className="h-3.5 w-3.5" /> Made for your next listen</p>
						<h1 class="max-w-xl text-4xl font-black leading-[0.94] tracking-[-0.055em] text-white sm:text-6xl">A music room built around your mood.</h1>
						<p class="mt-5 max-w-lg text-sm leading-6 text-white/65 sm:text-base">Search for a song, build a queue, and keep listening while you explore. Your player follows you everywhere.</p>
						<div class="mt-7 flex flex-wrap gap-3">
							<button class="mood-filter-trigger inline-flex items-center gap-2 rounded-full bg-primary px-5 py-3 text-sm font-black text-primary-foreground shadow-lg shadow-primary/30 transition hover:scale-[1.03] cursor-pointer" data-query="Trending music"><Play className="h-4 w-4 fill-current" /> Start listening</button>
							<a href="/explore" class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-black/20 px-5 py-3 text-sm font-bold text-white transition hover:bg-white/10">Explore music <ArrowRight className="h-4 w-4" /></a>
						</div>
					</div>
					<div class="hidden w-56 rotate-3 rounded-[1.6rem] border border-white/15 bg-gradient-to-br from-white/20 to-white/5 p-4 shadow-2xl backdrop-blur-sm lg:block">
						<div class="aspect-square rounded-2xl bg-[radial-gradient(circle_at_30%_25%,rgba(255,255,255,.9),rgba(255,255,255,.1)_25%,transparent_26%),linear-gradient(135deg,#ff725c,#4d1d4f_55%,#080808)] p-5">
							<div class="flex h-full items-end"><Radio className="h-10 w-10 text-white/90" /></div>
						</div>
						<p class="mt-4 text-xs font-black uppercase tracking-[0.17em] text-white/50">Your station</p>
						<p class="mt-1 font-bold text-white">Night-drive signal</p>
					</div>
				</div>
			</section>

			<!-- Mood Filter Bar -->
			<section class="flex gap-2.5 overflow-x-auto pb-2 scrollbar-hide snap-x snap-mandatory">
				{moodFilters.map((mood) => (
					<button class="mood-filter-trigger px-5 py-2 rounded-full bg-white/5 border border-white/5 hover:border-primary/40 hover:bg-white/10 transition-all whitespace-nowrap text-xs sm:text-sm font-bold tracking-tight text-white cursor-pointer snap-start" data-query={mood}>
						{mood}
					</button>
				))}
			</section>

			<!-- Dynamic Home Sections -->
			<div id="home-dynamic-content" class="space-y-12">
				<div class="flex flex-col items-center justify-center py-32 space-y-4 opacity-50">
					<div class="w-16 h-16 rounded-full bg-white/5 flex items-center justify-center border border-white/5">
						<Play className="w-8 h-8 text-primary animate-pulse" />
					</div>
					<p class="font-black tracking-tighter text-xl text-white">Waking up the music servers...</p>
				</div>
			</div>


		</div>
</Layout>

<script>
	import { fetchHome, searchSongs } from '../lib/api';

	const plays = ["28M plays", "1.1B plays", "401M plays", "139M plays", "92M plays", "15M plays", "310M plays", "64M plays"];
	const albums = ["No Dogs Allowed", "Favourite Worst Nightmare", "Currents", "Purple Rain", "Self Aware", "Vibe Engine", "Retro Waves"];
	
	const getMockDetails = (id: string) => {
		let sum = 0;
		for (let i = 0; i < id.length; i++) sum += id.charCodeAt(i);
		const play = plays[sum % plays.length];
		const album = albums[sum % albums.length];
		return `${play} • ${album}`;
	};

	async function loadHomeContent() {
		const container = document.getElementById('home-dynamic-content');
		if (!container) return;

		const homeSections = await fetchHome();
		if (homeSections && homeSections.length > 0) {
			container.innerHTML = homeSections.map((section: any, idx: number) => {
				// Style first section or recommendation sections as Quick Picks rows
				const isQuickPicks = section.title.toLowerCase().includes('recommended') || section.title.toLowerCase().includes('pick') || section.title.toLowerCase().includes('trend') || idx === 0;

				if (isQuickPicks) {
					return `
						<section class="animate-in fade-in duration-700 space-y-6">
							<div class="flex items-end justify-between">
								<div class="space-y-1">
									<p class="text-[10px] font-black uppercase tracking-[0.2em] text-primary">Curated for you</p>
									<h2 class="text-3xl font-black tracking-tighter text-white">Quick picks</h2>
								</div>
								<div class="flex items-center gap-3">
									<button class="px-4 py-1.5 rounded-full bg-white/5 border border-white/5 hover:bg-white/10 text-xs font-bold text-white transition-all cursor-pointer">Play all</button>
								</div>
							</div>

							<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-y-3.5 gap-x-6">
								${section.items.slice(0, 12).map((track: any) => {
									const details = getMockDetails(track.id);
									return `
										<div class="track-trigger flex items-center justify-between p-2 rounded-2xl hover:bg-white/5 group transition-all cursor-pointer"
											 data-id="${track.id}" data-title="${track.title}" data-artist="${track.artist}" data-artwork="${track.image}">
											<div class="flex items-center gap-3.5 pointer-events-none min-w-0 flex-1">
												<div class="relative w-12 h-12 rounded-xl overflow-hidden border border-white/5 bg-white/5 shrink-0">
													<img src="${track.image}" referrerpolicy="no-referrer" class="w-full h-full object-cover group-hover:scale-105 transition-all duration-500 opacity-0" onload="this.classList.remove('opacity-0')" onerror="this.onerror=null; this.src='https://i.ytimg.com/vi/${track.id}/hqdefault.jpg';" alt="${track.title}" />
													<div class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
														<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-white fill-current"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
													</div>
												</div>
												<div class="min-w-0">
													<h3 class="font-bold text-sm text-white truncate group-hover:text-primary transition-colors">${track.title}</h3>
													<p class="text-xs text-muted-foreground truncate font-medium mt-0.5">${track.artist} • ${details}</p>
												</div>
											</div>
											<button class="queue-add p-2.5 bg-white/5 rounded-xl border border-white/5 text-muted-foreground hover:text-white hover:bg-white/10 opacity-0 group-hover:opacity-100 transition-all ml-2">
												<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
											</button>
										</div>
									`;
								}).join('')}
							</div>
						</section>
					`;
				} else {
					return `
						<section class="animate-in fade-in duration-700 space-y-6">
							<div class="flex items-end justify-between">
								<div class="space-y-1">
									<p class="text-[10px] font-black uppercase tracking-[0.2em] text-primary">Listen Again</p>
									<h2 class="text-3xl font-black tracking-tighter text-white">${section.title}</h2>
								</div>
							</div>

							<!-- Horizontal scroll container on mobile, grid layout on desktop -->
							<div class="flex overflow-x-auto gap-4 md:grid md:grid-cols-4 xl:grid-cols-6 md:gap-6 pb-4 scrollbar-hide snap-x snap-mandatory">
								${section.items.map((track: any) => `
									<div class="track-trigger group flex-shrink-0 w-36 sm:w-44 md:w-auto space-y-3 cursor-pointer snap-start"
										 data-id="${track.id}" data-title="${track.title}" data-artist="${track.artist}" data-artwork="${track.image}">
										<div class="relative aspect-square rounded-[2rem] overflow-hidden shadow-xl border border-white/5 bg-white/5">
											<img src="${track.image}" referrerpolicy="no-referrer" class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105 opacity-0" onload="this.classList.remove('opacity-0')" onerror="this.onerror=null; this.src='https://i.ytimg.com/vi/${track.id}/hqdefault.jpg';" alt="${track.title}" />
											<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-all duration-500 flex items-end p-4">
												<div class="flex items-center gap-2 w-full">
													<div class="w-10 h-10 rounded-xl bg-primary text-primary-foreground flex items-center justify-center shadow-2xl shadow-primary/40 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
														<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 fill-current"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
													</div>
													<button class="queue-add p-2 bg-white/10 rounded-lg backdrop-blur-md opacity-0 group-hover:opacity-100 transition-all delay-75 hover:bg-white/20">
														<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-white"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
													</button>
												</div>
											</div>
										</div>
										<div class="space-y-1 px-1">
											<h3 class="font-bold text-sm truncate text-white group-hover:text-primary transition-colors">${track.title}</h3>
											<p class="text-xs text-muted-foreground truncate font-medium">${track.artist}</p>
										</div>
									</div>
								`).join('')}
							</div>
						</section>
					`;
				}
			}).join('');
		}
	}

	async function handleSearch(query: string) {
		const mainContent = document.getElementById('main-content-area');
		if (!mainContent) return;

		mainContent.innerHTML = `
			<div class="flex items-center gap-4 py-12">
				<div class="w-8 h-8 rounded-full border-2 border-primary border-t-transparent animate-spin"></div>
				<p class="font-black text-2xl tracking-tighter text-white">Searching for "${query}"...</p>
			</div>
		`;

		const songs = await searchSongs(query);
		
		mainContent.innerHTML = `
			<section class="animate-in fade-in slide-in-from-bottom-4 duration-700">
				<h2 class="text-4xl font-black tracking-tighter mb-8 text-white">Search results for "${query}"</h2>
				<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 2xl:grid-cols-6 gap-4 sm:gap-6 md:gap-8">
					${(songs && songs.length > 0) ? songs.map((track: any) => `
						<div class="track-trigger group space-y-3 cursor-pointer"
								data-id="${track.id}" data-title="${track.title}" data-artist="${track.artist}" data-artwork="${track.image}">
							<div class="relative aspect-square rounded-2xl sm:rounded-[2.2rem] overflow-hidden shadow-2xl border border-white/5 bg-white/5">
								<img src="${track.image}" referrerpolicy="no-referrer" class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105 opacity-0" onload="this.classList.remove('opacity-0')" onerror="this.onerror=null; this.src='https://i.ytimg.com/vi/${track.id}/hqdefault.jpg';" />
								<div class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-500">
									<div class="w-14 h-14 rounded-2xl bg-primary text-primary-foreground flex items-center justify-center shadow-2xl">
										<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
									</div>
								</div>
							</div>
							<div class="space-y-1 px-1">
								<h3 class="font-black text-lg truncate tracking-tight text-white group-hover:text-primary transition-colors">${track.title}</h3>
								<p class="text-xs text-muted-foreground font-bold uppercase tracking-widest">${track.artist}</p>
							</div>
						</div>
					`).join('') : '<p class="text-muted-foreground font-bold">No tracks found. Try a different search.</p>'}
				</div>
			</section>
		`;
	}

	document.addEventListener('astro:page-load', () => {
		if (window.location.pathname === '/') {
			const urlParams = new URLSearchParams(window.location.search);
			const query = urlParams.get('q');
			const searchInput = document.getElementById('global-search-input') as HTMLInputElement;
			const mobSearchInput = document.getElementById('mobile-search-input') as HTMLInputElement;
			let searchTimeout: any;

			const handleInput = (val: string) => {
				clearTimeout(searchTimeout);
				if (!val) {
					window.history.replaceState(null, '', '/');
					loadHomeContent();
					return;
				}
				window.history.replaceState(null, '', `/?q=${encodeURIComponent(val)}`);
				searchTimeout = setTimeout(() => handleSearch(val), 300);
			};

			if (searchInput) {
				if (!searchInput.dataset.homeBound) {
					searchInput.dataset.homeBound = "true";
					searchInput.addEventListener('input', (e) => {
						const val = (e.target as HTMLInputElement).value;
						handleInput(val);
					});
				}
			}

			if (mobSearchInput) {
				if (!mobSearchInput.dataset.homeBound) {
					mobSearchInput.dataset.homeBound = "true";
					mobSearchInput.addEventListener('input', (e) => {
						const val = (e.target as HTMLInputElement).value;
						handleInput(val);
					});
				}
			}

			if (query) {
				if (searchInput && document.activeElement !== searchInput) searchInput.value = query;
				if (mobSearchInput && document.activeElement !== mobSearchInput) mobSearchInput.value = query;
				handleSearch(query);
			} else {
				if (searchInput && document.activeElement !== searchInput) searchInput.value = "";
				if (mobSearchInput && document.activeElement !== mobSearchInput) mobSearchInput.value = "";
				loadHomeContent();
			}

			// Bind Mood Filter clicks to search in-place
			document.querySelectorAll('.mood-filter-trigger').forEach(triggerEl => {
				const trigger = triggerEl as HTMLElement;
				if (!trigger.dataset.bound) {
					trigger.dataset.bound = "true";
					trigger.addEventListener('click', () => {
						const q = trigger.dataset.query;
						if (q) {
							if (searchInput) searchInput.value = q;
							if (mobSearchInput) mobSearchInput.value = q;
							window.history.replaceState(null, '', `/?q=${encodeURIComponent(q)}`);
							handleSearch(q);
						}
					});
				}
			});
		}
	});
</script>

<style>
	.scrollbar-hide::-webkit-scrollbar {
		display: none;
	}
	.scrollbar-hide {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
</style>
