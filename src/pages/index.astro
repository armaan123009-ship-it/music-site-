---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import { Play, ChevronRight, ListPlus } from 'lucide-react';

const moodFilters = ["Energize", "Relax", "Focus", "Commute", "Workout", "Party", "Romance"];
---

<Layout title="Home | Premium Music Experience" activeNav="home">
	<Sidebar active="home" />

	<!-- Main Content Area -->
	<main class="xl:ml-64 flex-1 flex flex-col min-h-screen pb-32">

		<div id="main-content-area" class="p-4 sm:p-8 md:p-12 space-y-10 md:space-y-16">
			<!-- Mood Filter Bar -->
			<section class="flex gap-3 overflow-x-auto pb-4 scrollbar-hide">
				{moodFilters.map((mood) => (
					<button class="mood-filter-trigger px-6 py-2.5 rounded-2xl bg-white/5 border border-white/5 hover:border-primary/40 hover:bg-white/10 transition-all whitespace-nowrap text-sm font-bold tracking-tight text-white cursor-pointer" data-query={mood}>
						{mood}
					</button>
				))}
			</section>

			<!-- Dynamic Home Sections -->
			<div id="home-dynamic-content" class="space-y-16">
				<div class="flex flex-col items-center justify-center py-32 space-y-4 opacity-50">
					<div class="w-16 h-16 rounded-full bg-white/5 flex items-center justify-center border border-white/5">
						<Play className="w-8 h-8 text-primary animate-pulse" />
					</div>
					<p class="font-black tracking-tighter text-xl text-white">Waking up the music servers...</p>
				</div>
			</div>
		</div>
	</main>
</Layout>

<script>
	import { fetchHome, searchSongs } from '../lib/api';

	async function loadHomeContent() {
		const container = document.getElementById('home-dynamic-content');
		if (!container) return;

		const homeSections = await fetchHome();
		if (homeSections && homeSections.length > 0) {
			container.innerHTML = homeSections.map((section: any) => `
				<section class="animate-in fade-in duration-700">
					<div class="flex items-end justify-between mb-8">
						<div class="space-y-1">
							<p class="text-[10px] font-black uppercase tracking-[0.2em] text-primary">Curated for you</p>
							<h2 class="text-4xl font-black tracking-tighter text-white">${section.title}</h2>
						</div>
						<button class="flex items-center gap-2 text-xs font-black uppercase tracking-widest text-muted-foreground hover:text-white transition-colors">
							Listen All <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><polyline points="9 18 15 12 9 6"></polyline></svg>
						</button>
					</div>

					<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 2xl:grid-cols-6 gap-4 sm:gap-6 md:gap-8">
						${section.items.map((track: any) => `
							<div class="track-trigger group space-y-3 cursor-pointer"
								 data-id="${track.id}" data-title="${track.title}" data-artist="${track.artist}" data-artwork="${track.image}">
								<div class="relative aspect-square rounded-2xl sm:rounded-[2rem] overflow-hidden shadow-2xl border border-white/5 bg-white/5">
									<img src="${track.image}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" alt="${track.title}" />
									<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-all duration-500 flex items-end p-6">
										<div class="flex items-center gap-2 w-full">
											<div class="w-12 h-12 rounded-2xl bg-primary text-primary-foreground flex items-center justify-center shadow-2xl shadow-primary/40 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
												<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 fill-current"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
											</div>
											<button class="queue-add p-3 bg-white/10 rounded-xl backdrop-blur-md opacity-0 group-hover:opacity-100 transition-all delay-75 hover:bg-white/20">
												<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-white"><line x1="2" y1="12" x2="22" y2="12"></line><line x1="12" y1="2" x2="12" y2="22"></line></svg>
											</button>
										</div>
									</div>
								</div>
								<div class="space-y-1 px-1">
									<h3 class="font-black text-lg truncate tracking-tight text-white group-hover:text-primary transition-colors">${track.title}</h3>
									<p class="text-xs text-muted-foreground font-bold uppercase tracking-widest">${track.artist}</p>
								</div>
							</div>
						`).join('')}
					</div>
				</section>
			`).join('');
		}
	}

	async function handleSearch(query: string) {
		const mainContent = document.getElementById('main-content-area');
		if (!mainContent) return;

		mainContent.innerHTML = `
			<div class="flex items-center gap-4 py-12">
				<div class="w-8 h-8 rounded-full border-2 border-primary border-t-transparent animate-spin"></div>
				<p class="font-black text-2xl tracking-tighter text-white">Searching for "${query}"...</p>
			</div>
		`;

		const songs = await searchSongs(query);
		
		mainContent.innerHTML = `
			<section class="animate-in fade-in slide-in-from-bottom-4 duration-700">
				<h2 class="text-4xl font-black tracking-tighter mb-8 text-white">Search results for "${query}"</h2>
				<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 2xl:grid-cols-6 gap-4 sm:gap-6 md:gap-8">
					${(songs && songs.length > 0) ? songs.map((track: any) => `
						<div class="track-trigger group space-y-3 cursor-pointer"
								data-id="${track.id}" data-title="${track.title}" data-artist="${track.artist}" data-artwork="${track.image}">
							<div class="relative aspect-square rounded-2xl sm:rounded-[2.2rem] overflow-hidden shadow-2xl border border-white/5 bg-white/5">
								<img src="${track.image}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
								<div class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-500">
									<div class="w-14 h-14 rounded-2xl bg-primary text-primary-foreground flex items-center justify-center shadow-2xl">
										<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
									</div>
								</div>
							</div>
							<div class="space-y-1 px-1">
								<h3 class="font-black text-lg truncate tracking-tight text-white group-hover:text-primary transition-colors">${track.title}</h3>
								<p class="text-xs text-muted-foreground font-bold uppercase tracking-widest">${track.artist}</p>
							</div>
						</div>
					`).join('') : '<p class="text-muted-foreground font-bold">No tracks found. Try a different search.</p>'}
				</div>
			</section>
		`;
	}

	document.addEventListener('astro:page-load', () => {
		const urlParams = new URLSearchParams(window.location.search);
		const query = urlParams.get('q');
		const searchInput = document.getElementById('global-search-input') as HTMLInputElement;
		let searchTimeout: any;

		if (searchInput) {
			// Clean up duplicate listener bindings by checking sentinel
			if (!searchInput.dataset.homeBound) {
				searchInput.dataset.homeBound = "true";
				searchInput.addEventListener('input', (e) => {
					clearTimeout(searchTimeout);
					const val = (e.target as HTMLInputElement).value;
					if (!val) {
						window.history.replaceState(null, '', '/');
						loadHomeContent();
						return;
					}
					window.history.replaceState(null, '', `/?q=${encodeURIComponent(val)}`);
					searchTimeout = setTimeout(() => handleSearch(val), 500);
				});
			}

			if (query) {
				if (document.activeElement !== searchInput) {
					searchInput.value = query;
				}
				handleSearch(searchInput.value);
			} else {
				// Only clear input if the user is not actively focusing/typing there
				if (document.activeElement !== searchInput) {
					searchInput.value = "";
				}
				if (searchInput.value) {
					handleSearch(searchInput.value);
				} else {
					loadHomeContent();
				}
			}

			// Bind Mood Filter clicks to search in-place
			document.querySelectorAll('.mood-filter-trigger').forEach(trigger => {
				if (!trigger.dataset.bound) {
					trigger.dataset.bound = "true";
					trigger.addEventListener('click', () => {
						const q = (trigger as HTMLElement).dataset.query;
						if (q) {
							searchInput.value = q;
							window.history.replaceState(null, '', `/?q=${encodeURIComponent(q)}`);
							handleSearch(q);
						}
					});
				}
			});
		} else {
			loadHomeContent();
		}
	});
</script>

<style>
	.scrollbar-hide::-webkit-scrollbar {
		display: none;
	}
	.scrollbar-hide {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
</style>
